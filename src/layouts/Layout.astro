---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'gjsk132 blog',
	description = "gjsk132's blog",
} = Astro.props;
---

<!doctype html>
<html lang="ko">
	<script
	    data-goatcounter="https://gjsk132.goatcounter.com/count"
        async
		src="//gc.zgo.at/count.js"
	></script>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<slot name="head" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg: #f2f2f7;
		--panel: rgba(255, 255, 255, 0.72);
		--panel-strong: #fff;
		--text: #111;
		--muted: rgba(0, 0, 0, 0.52);
		--line: #e7e7e8;
		--shadow: 0 0 0.5rem rgba(0, 0, 0, 0.04);
		--accent: #4361ff;
		font-family:
			'Pretendard Variable', Pretendard, 'SUIT Variable', SUIT, 'Apple SD Gothic Neo',
			'Noto Sans KR', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		color: var(--text);
		background: var(--bg);
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background: var(--bg);
	}

	a {
		color: inherit;
	}
</style>
