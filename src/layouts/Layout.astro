---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'gjsk132 blog',
	description = "gjsk132's blog",
} = Astro.props;
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script
			data-goatcounter="https://gjsk132.goatcounter.com/count"
			async
			src="//gc.zgo.at/count.js"
		></script>
		<slot name="head" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--bg: #f2f2f7;
		--panel: rgba(255, 255, 255, 0.72);
		--panel-strong: #fff;
		--text: #111;
		--muted: rgba(0, 0, 0, 0.52);
		--line: #e7e7e8;
		--shadow: 0 0 0.5rem rgba(0, 0, 0, 0.04);
		--accent: #4361ff;
		font-family:
			'Pretendard Variable', Pretendard, 'SUIT Variable', SUIT, 'Apple SD Gothic Neo',
			'Noto Sans KR', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		color: var(--text);
		background: var(--bg);
	}

	* {
		box-sizing: border-box;
		scrollbar-width: none;
		-ms-overflow-style: none;
	}

	html {
		color-scheme: light;
		scrollbar-gutter: auto;
		scrollbar-width: none;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background: var(--bg);
		scrollbar-width: none;
		-ms-overflow-style: none;
	}

	a {
		color: inherit;
	}

	::-webkit-scrollbar {
		display: none;
		width: 0;
		height: 0;
	}

	::-webkit-scrollbar-track {
		background: transparent;
	}

	::-webkit-scrollbar-thumb {
		border: 3px solid transparent;
		border-radius: 999px;
		background: rgba(67, 97, 255, 0.32);
		background-clip: padding-box;
	}

	::-webkit-scrollbar-thumb:hover {
		background: rgba(67, 97, 255, 0.48);
		background-clip: padding-box;
	}

	::-webkit-scrollbar-corner {
		background: transparent;
	}
</style>
