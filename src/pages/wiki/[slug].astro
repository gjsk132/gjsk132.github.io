---
import BlogLayout from '../../components/BlogLayout.astro';
import WikiTermHighlighter from '../../components/WikiTermHighlighter.astro';
import Layout from '../../layouts/Layout.astro';
import { getAllWikiEntries } from '../../lib/wikiEntries';
import { getAllPosts, getPostCategories, getPostCategoryCounts, getPostTags } from '../../lib/posts';

export async function getStaticPaths() {
	const entries = await getAllWikiEntries();

	return entries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = entry;
const posts = await getAllPosts();
const categories = getPostCategories(posts);
const categoryCounts = getPostCategoryCounts(posts);
const tags = getPostTags(posts);
const entries = await getAllWikiEntries();
const wikiTermEntries = entries.filter((item) => item.slug !== entry.slug);
---

<Layout title={`${entry.title} | Wiki`} description={entry.definition}>
	<BlogLayout
		categories={categories}
		categoryCounts={categoryCounts}
		tags={tags}
		postCount={posts.length}
	>
		<article class="post-card wiki-detail-card">
			<h1>{entry.title}</h1>
			{entry.definitions.length === 0 && entry.definition && <p class="post-description">{entry.definition}</p>}
			{
				entry.definitions.length > 0 && (
					<div class="wiki-definitions">
						{entry.definitions.map((definition, index) => (
							<section>
								<span>[{index + 1}]</span>
								<strong>{definition.title}</strong>
								<p>{definition.define}</p>
							</section>
						))}
					</div>
				)
			}
			<hr class="content-divider" />

			<div class="article-content">
				<Content />
			</div>
			<WikiTermHighlighter entries={wikiTermEntries} />
		</article>

	</BlogLayout>
</Layout>

<script>
	function getCodeLanguage(pre: HTMLPreElement) {
		const languageFromData = pre.dataset.language;
		const code = pre.querySelector('code');
		const languageFromClass = Array.from(code?.classList ?? [])
			.find((className) => className.startsWith('language-'))
			?.replace('language-', '');

		return languageFromData ?? languageFromClass ?? 'code';
	}

	function isMermaidPre(pre: HTMLPreElement) {
		return getCodeLanguage(pre).trim().toLowerCase() === 'mermaid';
	}

	function enhanceCodeBlocks() {
		document.querySelectorAll<HTMLPreElement>('.article-content pre').forEach((pre) => {
			if (isMermaidPre(pre) || pre.closest('.code-block')) return;

			const wrapper = document.createElement('div');
			const header = document.createElement('div');
			const language = document.createElement('span');
			const button = document.createElement('button');
			const code = pre.querySelector('code');

			wrapper.className = 'code-block';
			header.className = 'code-block-header';
			language.className = 'code-language';
			language.textContent = getCodeLanguage(pre);
			button.className = 'code-copy-button';
			button.type = 'button';
			button.innerHTML =
				'<svg aria-hidden="true" viewBox="0 0 24 24"><path d="M8 7.5A2.5 2.5 0 0 1 10.5 5h6A2.5 2.5 0 0 1 19 7.5v9a2.5 2.5 0 0 1-2.5 2.5h-6A2.5 2.5 0 0 1 8 16.5v-9Zm2 0v9c0 .3.2.5.5.5h6c.3 0 .5-.2.5-.5v-9c0-.3-.2-.5-.5-.5h-6c-.3 0-.5.2-.5.5ZM5 14.5V6a3 3 0 0 1 3-3h6.5v2H8a1 1 0 0 0-1 1v8.5H5Z" /></svg>';
			button.setAttribute('aria-label', '코드 복사');
			button.title = '코드 복사';

			button.addEventListener('click', async () => {
				const codeText = code?.textContent ?? pre.textContent ?? '';

				try {
					await navigator.clipboard.writeText(codeText);
					button.dataset.copied = 'true';
					button.setAttribute('aria-label', '복사됨');
					button.title = '복사됨';
					window.setTimeout(() => {
						delete button.dataset.copied;
						button.setAttribute('aria-label', '코드 복사');
						button.title = '코드 복사';
					}, 1200);
				} catch {
					button.dataset.failed = 'true';
					button.setAttribute('aria-label', '복사 실패');
					button.title = '복사 실패';
					window.setTimeout(() => {
						delete button.dataset.failed;
						button.setAttribute('aria-label', '코드 복사');
						button.title = '코드 복사';
					}, 1200);
				}
			});

			header.append(language, button);
			pre.before(wrapper);
			wrapper.append(header, pre);
		});
	}

	function scheduleMermaidRender(callback: () => void) {
		if ('requestIdleCallback' in window) {
			window.requestIdleCallback(callback, { timeout: 1200 });
			return;
		}

		window.setTimeout(callback, 1);
	}

	enhanceCodeBlocks();

	scheduleMermaidRender(async () => {
		const mermaidBlocks = document.querySelectorAll<HTMLElement>(
			'.article-content pre[data-language="mermaid"] > code, .article-content pre > code.language-mermaid',
		);

		if (mermaidBlocks.length === 0) return;

		const { default: mermaid } = await import('mermaid');

		mermaid.initialize({
			startOnLoad: false,
			theme: 'default',
			securityLevel: 'strict',
		});

		for (const block of mermaidBlocks) {
			const pre = block.parentElement;
			if (!pre) continue;

			const container = document.createElement('div');
			container.className = 'mermaid';
			container.textContent = block.textContent ?? '';
			pre.replaceWith(container);
		}

		const renderedMermaidBlocks = document.querySelectorAll<HTMLElement>('.article-content .mermaid');

		await mermaid.run({ nodes: renderedMermaidBlocks });
	});
</script>

<style>
	.post-card {
		padding: 40px;
		background: var(--panel);
		border-radius: 24px;
		box-shadow: 0 20px 48px rgba(20, 24, 40, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.9);
	}

	h1 {
		font-size: 34px;
		line-height: 1.25;
		margin: 0 0 10px;
		overflow-wrap: anywhere;
	}

	.post-description {
		margin: 0 0 18px;
		color: var(--muted);
		font-size: 14px;
		line-height: 1.7;
	}

	.wiki-definitions {
		display: grid;
		gap: 11px;
		margin: 18px 0 22px;
	}

	.wiki-definitions section {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		column-gap: 8px;
		row-gap: 4px;
		padding-left: 12px;
		border-left: 2px solid color-mix(in srgb, var(--accent) 68%, white);
	}

	.wiki-definitions span {
		color: var(--accent);
		font-size: 12px;
		font-weight: 800;
		line-height: 1.35;
	}

	.wiki-definitions strong {
		color: var(--text);
		font-size: 13px;
		line-height: 1.35;
	}

	.wiki-definitions p {
		grid-column: 2;
		margin: 0;
		color: var(--muted);
		font-size: 13px;
		line-height: 1.65;
	}

	.meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
		min-width: 0;
		color: var(--muted);
		font-size: 13px;
		margin-bottom: 34px;
	}

	.meta span {
		max-width: 100%;
		padding: 4px 8px;
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		font-weight: 700;
		overflow-wrap: anywhere;
	}

	.content-divider {
		height: 1px;
		margin: 0 0 28px;
		border: 0;
		background: var(--line);
	}

	.article-content {
		font-size: 14px;
	}

	.article-content :global(h2) {
		margin-top: 34px;
		font-size: 20px;
	}

	.article-content :global(h3) {
		font-size: 17px;
	}

	.article-content :global(p),
	.article-content :global(li) {
		line-height: 1.75;
	}

	.article-content :global(a) {
		color: var(--accent);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition:
			color 160ms ease,
			text-decoration-color 160ms ease;
	}

	.article-content :global(a:hover),
	.article-content :global(a:focus-visible) {
		color: color-mix(in srgb, var(--accent) 78%, black);
		text-decoration-color: currentColor;
		outline: 0;
	}

	.article-content :global(img) {
		display: block;
		max-width: 100%;
		height: auto;
		border-radius: 16px;
	}

	.article-content :global(pre) {
		overflow-x: auto;
		margin: 22px 0;
		padding: 18px;
		border-radius: 16px;
		background: #f8f9fc !important;
		border: 1px solid var(--line);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.article-content :global(.code-block) {
		position: relative;
		margin: 22px 0;
		border-radius: 10px;
		background: #fff;
		border: 1px solid var(--line);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.72),
			0 16px 34px rgba(20, 24, 40, 0.08);
		overflow: hidden;
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.article-content :global(.code-block:hover) {
		border-color: color-mix(in srgb, var(--accent) 24%, var(--line));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.82),
			0 18px 38px rgba(20, 24, 40, 0.1);
	}

	.article-content :global(.code-block pre) {
		margin: 0;
		padding: 18px 18px 20px;
		border: 0;
		border-radius: 0;
		background: transparent !important;
		box-shadow: none;
	}

	.article-content :global(.code-block pre:hover) {
		border-color: transparent;
		box-shadow: none;
	}

	.article-content :global(.code-block-header) {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		height: 34px;
		padding: 0 10px 0 66px;
		background: #f1f3f8;
		border-bottom: 1px solid var(--line);
		pointer-events: none;
	}

	.article-content :global(.code-block-header::before) {
		content: '';
		position: absolute;
		left: 16px;
		top: 50%;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #d5dae6;
		box-shadow:
			12px 0 0 #d5dae6,
			24px 0 0 #d5dae6;
		transform: translateY(-50%);
	}

	.article-content :global(.code-language) {
		color: var(--accent);
		font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, monospace;
		font-size: 10px;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.article-content :global(.code-copy-button) {
		pointer-events: auto;
		width: 28px;
		height: 28px;
		display: grid;
		place-items: center;
		padding: 0;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		color: var(--muted);
		cursor: pointer;
		transition:
			background 160ms ease,
			border-color 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.article-content :global(.code-copy-button svg) {
		width: 16px;
		height: 16px;
		fill: currentColor;
	}

	.article-content :global(.code-copy-button:hover),
	.article-content :global(.code-copy-button:focus-visible) {
		border-color: color-mix(in srgb, var(--accent) 34%, var(--line));
		background: color-mix(in srgb, var(--accent) 10%, white);
		color: var(--accent);
		transform: translateY(-1px);
		outline: 0;
	}

	.article-content :global(.code-copy-button[data-copied='true']) {
		border-color: rgba(32, 143, 81, 0.28);
		background: rgba(32, 143, 81, 0.1);
		color: #208f51;
	}

	.article-content :global(.code-copy-button[data-failed='true']) {
		border-color: rgba(210, 55, 55, 0.28);
		background: rgba(210, 55, 55, 0.1);
		color: #d23737;
	}

	.article-content :global(pre:hover) {
		border-color: rgba(67, 97, 255, 0.34);
		box-shadow: 0 12px 28px rgba(20, 24, 40, 0.06);
	}

	.article-content :global(pre[data-language='mermaid']),
	.article-content :global(pre:has(> code.language-mermaid)) {
		position: relative;
		min-height: 120px;
		overflow: hidden;
		margin: 24px 0;
		background: var(--panel-strong) !important;
		border: 1px solid var(--line);
		color: transparent;
		user-select: none;
	}

	.article-content :global(pre[data-language='mermaid'] code),
	.article-content :global(pre:has(> code.language-mermaid) code) {
		opacity: 0;
	}

	.article-content :global(pre[data-language='mermaid']::before),
	.article-content :global(pre:has(> code.language-mermaid)::before) {
		content: '';
		position: absolute;
		inset: 16px;
		border-radius: 12px;
		background:
			linear-gradient(90deg, transparent, rgba(67, 97, 255, 0.08), transparent),
			color-mix(in srgb, var(--accent) 4%, white);
	}

	.article-content :global(code) {
		font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, monospace;
	}

	.article-content :global(.mermaid) {
		display: flex;
		justify-content: center;
		overflow-x: auto;
		margin: 24px 0;
		padding: 16px;
		border-radius: 16px;
		background: var(--panel-strong);
		border: 1px solid var(--line);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.article-content :global(.mermaid:hover) {
		border-color: color-mix(in srgb, var(--accent) 18%, var(--line));
		box-shadow: 0 12px 28px rgba(20, 24, 40, 0.06);
	}

	.article-content :global(.mermaid svg) {
		max-width: 100%;
		height: auto;
	}

	.post-neighbors {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
		margin-top: 16px;
		padding: 16px;
		border: 1px solid rgba(255, 255, 255, 0.58);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.18);
		box-shadow: 0 20px 48px rgba(20, 24, 40, 0.08);
	}

	.post-neighbors a {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 9px;
		min-width: 0;
		min-height: 118px;
		padding: 18px;
		border: 1px solid rgba(255, 255, 255, 0.82);
		border-radius: 18px;
		background: var(--panel-strong);
		color: var(--text);
		text-decoration: none;
		width: 100%;
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.post-neighbors a:hover,
	.post-neighbors a:focus-visible {
		border-color: color-mix(in srgb, var(--accent) 24%, white);
		box-shadow: 0 12px 30px rgba(45, 84, 255, 0.08);
		transform: translateY(-1px);
		outline: 0;
	}

	.post-neighbors span {
		color: var(--muted);
		font-size: 12px;
		font-weight: 700;
	}

	.post-neighbors strong {
		width: 100%;
		min-width: 0;
		color: var(--text);
		font-size: 15px;
		line-height: 1.4;
		overflow-wrap: anywhere;
	}

	.post-neighbors p {
		display: -webkit-box;
		margin: 0;
		color: var(--muted);
		font-size: 12px;
		line-height: 1.6;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.neighbor-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 6px;
		width: 100%;
		min-width: 0;
	}

	.post-neighbors em {
		max-width: 100%;
		padding: 4px 8px;
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		font-size: 11px;
		font-style: normal;
		font-weight: 700;
		overflow-wrap: anywhere;
	}

	@media (max-width: 900px) {
		.post-card {
			padding: 24px 18px;
		}

		h1 {
			font-size: 25px;
		}

		.post-neighbors {
			grid-template-columns: 1fr;
			padding: 12px;
		}
	}
</style>
