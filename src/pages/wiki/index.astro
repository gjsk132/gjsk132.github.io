---
import BlogLayout from '../../components/BlogLayout.astro';
import Layout from '../../layouts/Layout.astro';
import { getAllWikiEntries } from '../../lib/wikiEntries';
import { getAllPosts, getPostCategories, getPostCategoryCounts, getPostTags } from '../../lib/posts';

const posts = await getAllPosts();
const categories = getPostCategories(posts);
const categoryCounts = getPostCategoryCounts(posts);
const postTags = getPostTags(posts);
const entries = await getAllWikiEntries();

function entryAnchor(entry: (typeof entries)[number]) {
	return `entry-${entry.slug.replace(/[^A-Za-z0-9_-]+/g, '-')}`;
}

function entryHref(entry: (typeof entries)[number]) {
	return `/wiki/${entry.slug}/`;
}

function definitionSearchText(entry: (typeof entries)[number]) {
	return [entry.definition, ...entry.definitions.flatMap((definition) => [definition.title, definition.define])]
		.join(' ')
		.toLowerCase();
}

function definitionCount(entry: (typeof entries)[number]) {
	return entry.definitions.length || (entry.definition ? 1 : 0);
}
---

<Layout title="Wiki | gjsk132 blog" description="Obsidian wiki 노트를 모아 보는 페이지">
	<BlogLayout categories={categories} categoryCounts={categoryCounts} tags={postTags} postCount={posts.length}>
		<section class="wiki-frame">
			<header class="wiki-header">
				<div>
					<h1>
						<span>Wiki</span>
						<strong>{entries.length}</strong>
					</h1>
				</div>
			</header>

			<label class="wiki-search">
				<svg aria-hidden="true" viewBox="0 0 24 24">
					<path d="M10.8 4.5a6.3 6.3 0 0 1 5 10.1l3.8 3.8a1 1 0 0 1-1.4 1.4l-3.8-3.8a6.3 6.3 0 1 1-3.6-11.5Zm0 2a4.3 4.3 0 1 0 0 8.6 4.3 4.3 0 0 0 0-8.6Z" />
				</svg>
				<input type="search" placeholder="Wiki 검색" data-wiki-search />
			</label>

			{
				entries.length > 0 ? (
					<ul class="wiki-list" data-wiki-list data-view="posts">
						{entries.map((entry) => (
							<li
								class="wiki-card"
										data-wiki-item
										data-title={entry.title.toLowerCase()}
										data-definition={definitionSearchText(entry)}
									>
								<a
									href={entryHref(entry)}
									id={entryAnchor(entry)}
								>
									<span class="wiki-card-title">{entry.title}</span>
									<span class="wiki-card-count">
										{definitionCount(entry)}
									</span>
									{
										entry.definitions.length > 0 ? (
											<span class="wiki-card-definitions">
												{entry.definitions.map((definition) => (
													<span>
														<strong>{definition.title}</strong>
														<em>{definition.define}</em>
													</span>
												))}
											</span>
										) : (
											<span class="wiki-card-definition">{entry.definition}</span>
										)
									}
								</a>
							</li>
						))}
					</ul>
				) : (
					<p class="empty-wiki">content/wiki 폴더에 Markdown 파일을 추가하면 Wiki에 표시됩니다.</p>
				)
			}
			<p class="empty-wiki" data-empty-wiki hidden>검색 조건과 맞는 Wiki 항목이 없습니다.</p>
		</section>
	</BlogLayout>
</Layout>

<script>
	const searchInput = document.querySelector<HTMLInputElement>('[data-wiki-search]');
	const items = Array.from(document.querySelectorAll<HTMLElement>('[data-wiki-item]'));
	const emptyWiki = document.querySelector<HTMLElement>('[data-empty-wiki]');
	const wikiList = document.querySelector<HTMLElement>('[data-wiki-list]');

	function setWikiViewMode(viewMode: string) {
		const nextViewMode = viewMode === 'timeline' ? 'timeline' : 'posts';
		if (wikiList) {
			wikiList.dataset.view = nextViewMode;
		}
	}

	function applyWikiFilters() {
		const query = searchInput?.value.trim().toLowerCase() ?? '';
		let visibleCount = 0;

		for (const item of items) {
			const matchesQuery =
				!query ||
				(item.dataset.title ?? '').includes(query) ||
				(item.dataset.definition ?? '').includes(query);

			item.hidden = !matchesQuery;
			if (matchesQuery) visibleCount += 1;
		}

		if (emptyWiki) {
			emptyWiki.hidden = visibleCount > 0;
		}
	}

	searchInput?.addEventListener('input', applyWikiFilters);
	setWikiViewMode(window.localStorage.getItem('postViewMode') ?? 'posts');

	window.addEventListener('post-view-mode-change', (event) => {
		setWikiViewMode(String((event as CustomEvent<string>).detail ?? 'posts'));
	});
</script>

<style>
	.wiki-frame {
		padding: 28px 22px 40px;
		border: 1px solid rgba(255, 255, 255, 0.58);
		border-radius: 20px;
		background: rgba(255, 255, 255, 0.18);
		box-shadow: 0 20px 48px rgba(20, 24, 40, 0.08);
	}

	.wiki-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		padding-bottom: 20px;
		border-bottom: 1px solid var(--line);
		margin: 0 0 20px;
	}

	.wiki-header h1 {
		display: flex;
		align-items: baseline;
		gap: 8px;
		margin: 0;
		font-size: 23px;
		font-weight: 800;
		line-height: 1.25;
	}

	.wiki-header h1 strong {
		color: var(--accent);
		font-size: 23px;
		line-height: 1.2;
	}

	.wiki-search {
		display: flex;
		align-items: center;
		gap: 10px;
		width: min(450px, 100%);
		height: 42px;
		padding: 0 14px;
		border: 1px solid rgba(255, 255, 255, 0.72);
		border-radius: 20px;
		background: var(--panel-strong);
		box-shadow: var(--shadow);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.wiki-search:focus-within {
		border-color: color-mix(in srgb, var(--accent) 32%, white);
		box-shadow: 0 14px 32px rgba(45, 84, 255, 0.1);
	}

	.wiki-search svg {
		width: 16px;
		height: 16px;
		flex: 0 0 auto;
		fill: var(--muted);
	}

	.wiki-search input {
		width: 100%;
		min-width: 0;
		border: 0;
		background: transparent;
		color: var(--text);
		font-size: 13px;
		outline: 0;
	}

	.wiki-list {
		column-count: 2;
		column-gap: 22px;
		margin: 22px 0 0;
		padding: 0;
		list-style: none;
	}

	.wiki-card[hidden] {
		display: none;
	}

	.wiki-card {
		break-inside: avoid;
		margin: 0 0 22px;
	}

	.wiki-card a {
		position: relative;
		display: grid;
		gap: 10px;
		min-height: 148px;
		padding: 22px 20px;
		border: 1px solid rgba(255, 255, 255, 0.82);
		border-radius: 20px;
		background: var(--panel-strong);
		color: var(--text);
		text-decoration: none;
		box-shadow: none;
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.wiki-card a:hover,
	.wiki-card a:focus-visible {
		border-color: color-mix(in srgb, var(--accent) 24%, white);
		box-shadow: 0 12px 30px rgba(45, 84, 255, 0.08);
		transform: translateY(-1px);
		outline: 0;
	}

	.wiki-card-title {
		font-size: 16px;
		font-weight: 700;
		line-height: 1.35;
		overflow-wrap: anywhere;
	}

	.wiki-card-title::after {
		content: '';
		display: block;
		width: 30px;
		height: 2px;
		margin-top: 7px;
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 72%, white);
	}

	.wiki-card-count {
		display: none;
	}

	.wiki-card-definition {
		display: -webkit-box;
		color: var(--muted);
		font-size: 12px;
		line-height: 1.62;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.wiki-card-definitions {
		display: grid;
		gap: 8px;
	}

	.wiki-card-definitions > span {
		display: grid;
		gap: 3px;
		padding-left: 10px;
		border-left: 2px solid color-mix(in srgb, var(--accent) 18%, white);
	}

	.wiki-card-definitions strong {
		color: var(--text);
		font-size: 12px;
		line-height: 1.35;
		overflow-wrap: anywhere;
	}

	.wiki-card-definitions em {
		display: -webkit-box;
		color: var(--muted);
		font-size: 12px;
		font-style: normal;
		line-height: 1.55;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.wiki-list[data-view='timeline'] {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		column-gap: 18px;
		row-gap: 12px;
		max-width: none;
		column-count: initial;
	}

	.wiki-list[data-view='timeline'] .wiki-card {
		margin: 0;
	}

	.wiki-list[data-view='timeline'] .wiki-card a {
		display: flex;
		align-items: center;
		gap: 10px;
		width: fit-content;
		max-width: 100%;
		min-height: 42px;
		padding: 11px 19px;
		border-radius: 999px;
		background: #fff;
		box-shadow: none;
		overflow: visible;
	}

	.wiki-list[data-view='timeline'] .wiki-card a::before {
		content: '';
		width: 7px;
		height: 7px;
		flex: 0 0 auto;
		border: 3px solid color-mix(in srgb, var(--accent) 18%, white);
		border-radius: 50%;
		background: var(--accent);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.wiki-list[data-view='timeline'] .wiki-card a:hover,
	.wiki-list[data-view='timeline'] .wiki-card a:focus-visible {
		box-shadow: 0 12px 28px rgba(20, 24, 40, 0.08);
	}

	.wiki-list[data-view='timeline'] .wiki-card a:hover::before,
	.wiki-list[data-view='timeline'] .wiki-card a:focus-visible::before {
		border-color: color-mix(in srgb, var(--accent) 28%, white);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 8%, transparent);
		transform: scale(1.08);
	}

	.wiki-list[data-view='timeline'] .wiki-card-title {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		font-size: 14px;
	}

	.wiki-list[data-view='timeline'] .wiki-card-title::after {
		display: none;
	}

	.wiki-list[data-view='timeline'] .wiki-card-definition,
	.wiki-list[data-view='timeline'] .wiki-card-definitions {
		display: none;
	}

	.wiki-list[data-view='timeline'] .wiki-card-count {
		display: inline;
		color: var(--muted);
		font-size: 12px;
		font-weight: 600;
	}

	.empty-wiki {
		margin: 18px 0 0;
		color: var(--muted);
		font-size: 13px;
		line-height: 1.7;
	}

	.empty-wiki[hidden] {
		display: none;
	}

	@media (max-width: 900px) {
		.wiki-frame {
			padding: 24px 18px;
		}

		.wiki-header {
			align-items: flex-start;
			flex-direction: column;
		}

		.wiki-list {
			column-count: 1;
		}

	}
</style>
