---
import BlogLayout from '../components/BlogLayout.astro';
import Layout from '../layouts/Layout.astro';
import {
	formatPostDate,
	getAllPosts,
	getPostCategories,
	getPostCategoryCounts,
	getPostDate,
	getPostTags,
} from '../lib/posts';

const posts = await getAllPosts();
const categories = getPostCategories(posts);
const categoryCounts = getPostCategoryCounts(posts);
const tags = getPostTags(posts);
const initialCategory = Astro.url.searchParams.get('category');
const initialTag = Astro.url.searchParams.get('tag');
const initialFilteredPosts = posts.filter((post) => {
	if (initialCategory) return postCategory(post) === initialCategory;
	if (initialTag) return postTags(post).includes(initialTag);
	return true;
});
const initialListTitle = initialCategory ?? (initialTag ? `#${initialTag}` : 'HOME');
const initialPostCount = initialFilteredPosts.length;

function postCategory(post: (typeof posts)[number]) {
	return post.frontmatter.category ?? post.frontmatter.categories?.[0] ?? 'none';
}

function postTags(post: (typeof posts)[number]) {
	return post.frontmatter.tags ?? [];
}

function postYear(post: (typeof posts)[number]) {
	const date = getPostDate(post);
	return date ? new Date(date).getFullYear().toString() : '';
}

function postMonthDay(post: (typeof posts)[number]) {
	const date = getPostDate(post);
	if (!date) return '';

	return new Intl.DateTimeFormat('ko-KR', {
		month: '2-digit',
		day: '2-digit',
	})
		.format(new Date(date))
		.replace(/\. /g, '-')
		.replace('.', '');
}

function plainPostBody(post: (typeof posts)[number]) {
	return post.body
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/!\[\[[^\]]+\]\]/g, ' ')
		.replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
		.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
		.replace(/[#>*_`~|[\]-]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();
}

function searchPreview(post: (typeof posts)[number]) {
	return plainPostBody(post) || post.excerpt;
}
---

<Layout title="gjsk132 blog" description="gjsk132's blog">
	<script is:inline>
		const routeFilterParams = new URLSearchParams(window.location.search);
		if (routeFilterParams.has('category') || routeFilterParams.has('tag')) {
			document.documentElement.dataset.routeFilterPending = 'true';
		}
	</script>
	<BlogLayout categories={categories} categoryCounts={categoryCounts} tags={tags} postCount={posts.length}>
		<section class="home-post-frame">
			<section class="search-panel" data-search-panel hidden>
				<h1 class="search-title">Search</h1>
				<label class="search-field">
					<svg aria-hidden="true" viewBox="0 0 24 24">
						<path d="M10.8 4.5a6.3 6.3 0 0 1 5 10.1l3.8 3.8a1 1 0 0 1-1.4 1.4l-3.8-3.8a6.3 6.3 0 1 1-3.6-11.5Zm0 2a4.3 4.3 0 1 0 0 8.6 4.3 4.3 0 0 0 0-8.6Z" />
					</svg>
					<input type="search" placeholder="검색어를 입력하세요" data-search-input />
				</label>
				<div class="search-results" data-search-results>
					{
						posts.map((post) => (
							<a
								href={`/blog/${post.slug}/`}
								data-search-result
								data-search-title={(post.frontmatter.title ?? post.slug).toLowerCase()}
								data-search-body={plainPostBody(post).toLowerCase()}
								data-result-title={post.frontmatter.title ?? post.slug}
								data-result-preview={searchPreview(post)}
								hidden
							>
								<strong data-result-title-text>{post.frontmatter.title ?? post.slug}</strong>
								<p data-result-preview-text>{searchPreview(post)}</p>
								<div class="search-result-meta">
									<span>{postCategory(post)}</span>
									{postTags(post).map((tag) => <span>#{tag}</span>)}
								</div>
							</a>
						))
					}
				</div>
				<p class="empty-search" data-empty-search hidden>검색 결과가 없습니다.</p>
			</section>

			<h1 class="home-title" data-filter-title>
				<span class="home-title-text">
					<span data-post-list-title>{initialListTitle}</span>
					<strong data-visible-post-count>{initialPostCount}</strong>
				</span>
				<span class="page-size-control" aria-label="페이지당 게시글 수">
					<button type="button" data-page-size-option="5" aria-pressed="true">5</button>
					<button type="button" data-page-size-option="10" aria-pressed="false">10</button>
					<button type="button" data-page-size-option="20" aria-pressed="false">20</button>
				</span>
			</h1>

			{
				posts.length > 0 ? (
					<ul class="home-post-list" data-post-list data-view="posts">
						{posts.map((post) => (
							<li
								data-post-item
								data-category={postCategory(post)}
								data-tags={postTags(post).join('|')}
								data-year={postYear(post)}
								hidden={!initialFilteredPosts.includes(post)}
							>
								<div class="timeline-date" aria-hidden="true">
									<strong data-timeline-year></strong>
									<span>{postMonthDay(post)}</span>
								</div>
								<a href={`/blog/${post.slug}/`}>
									<h2 class="home-post-title">{post.frontmatter.title ?? post.slug}</h2>
									{post.excerpt && <p>{post.excerpt}</p>}
									<div class="home-post-meta">
										<span>{postCategory(post)}</span>
										{getPostDate(post) && (
											<>
												<i aria-hidden="true"></i>
												<time datetime={new Date(getPostDate(post)!).toISOString()}>
													{formatPostDate(getPostDate(post))}
												</time>
											</>
										)}
										{post.frontmatter.tags?.length > 0 && (
											<>
												<i aria-hidden="true"></i>
												<div class="home-post-tags">
													{post.frontmatter.tags.map((tag) => <em>{tag}</em>)}
												</div>
											</>
										)}
									</div>
								</a>
							</li>
						))}
					</ul>
				) : (
					<p>아직 등록된 글이 없습니다. content/post 폴더에 Markdown 파일을 추가해 주세요.</p>
				)
			}
			<p class="empty-filter" data-empty-filter hidden>선택한 조건에 등록된 글이 없습니다.</p>
			<nav class="pagination" aria-label="게시글 페이지" data-pagination hidden>
				<button type="button" data-page-prev aria-label="이전 페이지">Prev</button>
				<span data-page-status></span>
				<button type="button" data-page-next aria-label="다음 페이지">Next</button>
			</nav>
		</section>
	</BlogLayout>
</Layout>

<script>
	const selectedCategory = new URLSearchParams(window.location.search).get('category');
	const selectedTag = new URLSearchParams(window.location.search).get('tag');
	const shouldOpenSearch = new URLSearchParams(window.location.search).has('search');
	const filterTitle = document.querySelector<HTMLElement>('[data-filter-title]');
	const postListTitle = document.querySelector<HTMLElement>('[data-post-list-title]');
	const postList = document.querySelector<HTMLElement>('[data-post-list]');
	const postItems = Array.from(document.querySelectorAll<HTMLElement>('[data-post-item]'));
	const visiblePostCount = document.querySelector<HTMLElement>('[data-visible-post-count]');
	const emptyFilter = document.querySelector<HTMLElement>('[data-empty-filter]');
	const viewButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-view-button]'));
	const searchPanel = document.querySelector<HTMLElement>('[data-search-panel]');
	const searchInput = document.querySelector<HTMLInputElement>('[data-search-input]');
	const searchResults = Array.from(document.querySelectorAll<HTMLElement>('[data-search-result]'));
	const emptySearch = document.querySelector<HTMLElement>('[data-empty-search]');
	const pageSizeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-page-size-option]'));
	const pagination = document.querySelector<HTMLElement>('[data-pagination]');
	const pagePrev = document.querySelector<HTMLButtonElement>('[data-page-prev]');
	const pageNext = document.querySelector<HTMLButtonElement>('[data-page-next]');
	const pageStatus = document.querySelector<HTMLElement>('[data-page-status]');
	const mobilePaginationQuery = window.matchMedia('(max-width: 900px)');
	let searchQuery = '';
	let currentViewMode = 'posts';
	let currentPage = 1;
	let pageSize = mobilePaginationQuery.matches ? 10 : Number(window.localStorage.getItem('postPageSize') ?? '5');

	if (![5, 10, 20].includes(pageSize)) {
		pageSize = mobilePaginationQuery.matches ? 10 : 5;
	}

	function syncMobilePageSize() {
		if (!mobilePaginationQuery.matches) return;

		pageSize = 10;
		currentPage = 1;

		for (const pageSizeButton of pageSizeButtons) {
			pageSizeButton.setAttribute('aria-pressed', String(Number(pageSizeButton.dataset.pageSizeOption) === 10));
		}

		applyPostFilters();
	}

	function updateTimelineYears() {
		let currentYear = '';
		let lastVisibleItem: HTMLElement | undefined;

		for (const item of postItems) {
			delete item.dataset.lastVisible;

			const yearLabel = item.querySelector<HTMLElement>('[data-timeline-year]');
			if (!yearLabel) continue;

			if (item.hidden) {
				yearLabel.textContent = '';
				continue;
			}

			const year = item.dataset.year ?? '';
			yearLabel.textContent = year && year !== currentYear ? year : '';
			if (year) currentYear = year;
			lastVisibleItem = item;
		}

		if (lastVisibleItem) {
			lastVisibleItem.dataset.lastVisible = 'true';
		}
	}

	function matchesRouteFilter(item: HTMLElement) {
		if (!selectedCategory && !selectedTag) return true;

		const itemTags = item.dataset.tags?.split('|').filter(Boolean) ?? [];
		return selectedCategory
			? item.dataset.category === selectedCategory
			: itemTags.includes(selectedTag ?? '');
	}

	function applyPostFilters() {
		const matchedItems = postItems.filter((item) => matchesRouteFilter(item));
		const matchedItemIndexes = new Map(matchedItems.map((item, index) => [item, index]));
		const visibleCount = matchedItems.length;
		const shouldPaginate = currentViewMode === 'posts';
		const totalPages = shouldPaginate ? Math.max(1, Math.ceil(visibleCount / pageSize)) : 1;

		currentPage = Math.min(currentPage, totalPages);
		const pageStart = (currentPage - 1) * pageSize;
		const pageEnd = pageStart + pageSize;

		for (const item of postItems) {
			const matchedIndex = matchedItemIndexes.get(item) ?? -1;
			const isVisible =
				matchedIndex >= 0 && (!shouldPaginate || (matchedIndex >= pageStart && matchedIndex < pageEnd));
			item.hidden = !isVisible;
		}

		if (visiblePostCount) {
			visiblePostCount.textContent = String(visibleCount);
		}

		if (emptyFilter) {
			emptyFilter.hidden = visibleCount > 0;
		}

		if (pagination) {
			pagination.hidden = !shouldPaginate || visibleCount <= pageSize;
		}

		if (pageStatus) {
			pageStatus.textContent = `${currentPage} / ${totalPages}`;
		}

		if (pagePrev) {
			pagePrev.disabled = currentPage <= 1;
		}

		if (pageNext) {
			pageNext.disabled = currentPage >= totalPages;
		}

		updateTimelineYears();
	}

	function applySearchResults() {
		if (!searchQuery) {
			for (const result of searchResults) {
				result.hidden = true;
			}

			if (emptySearch) {
				emptySearch.hidden = true;
			}

			if (searchPanel) {
				searchPanel.dataset.searchActive = 'false';
			}

			return;
		}

		let visibleCount = 0;

		for (const result of searchResults) {
			const title = result.dataset.searchTitle ?? '';
			const body = result.dataset.searchBody ?? '';
			const isVisible = Boolean(searchQuery) && (title.includes(searchQuery) || body.includes(searchQuery));
			const resultTitle = result.querySelector<HTMLElement>('[data-result-title-text]');
			const resultPreview = result.querySelector<HTMLElement>('[data-result-preview-text]');

			if (resultTitle) {
				resultTitle.innerHTML = highlightText(result.dataset.resultTitle ?? '', searchQuery);
			}

			if (resultPreview) {
				resultPreview.innerHTML = highlightText(result.dataset.resultPreview ?? '', searchQuery);
			}

			result.hidden = !isVisible;
			if (isVisible) visibleCount += 1;
		}

		if (emptySearch) {
			emptySearch.hidden = !searchQuery || visibleCount > 0;
		}

		if (searchPanel) {
			searchPanel.dataset.searchActive = String(Boolean(searchQuery));
		}
	}

	function escapeHtml(value: string) {
		return value.replace(/[&<>"']/g, (char) => {
			const entities: Record<string, string> = {
				'&': '&amp;',
				'<': '&lt;',
				'>': '&gt;',
				'"': '&quot;',
				"'": '&#39;',
			};
			return entities[char];
		});
	}

	function escapeRegExp(value: string) {
		return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
	}

	function highlightText(value: string, query: string) {
		const escapedValue = escapeHtml(value);
		if (!query) return escapedValue;

		return escapedValue.replace(
			new RegExp(`(${escapeRegExp(escapeHtml(query))})`, 'gi'),
			'<mark>$1</mark>',
		);
	}

	function setViewMode(viewMode: string) {
		const nextViewMode = viewMode === 'timeline' ? 'timeline' : 'posts';
		currentViewMode = nextViewMode;

		if (postList) {
			postList.dataset.view = nextViewMode;
		}

		if (filterTitle) {
			filterTitle.dataset.viewMode = nextViewMode;
		}

		for (const button of viewButtons) {
			button.setAttribute('aria-pressed', String(button.dataset.viewButton === nextViewMode));
		}

		window.localStorage.setItem('postViewMode', nextViewMode);
		applyPostFilters();
	}

	function scheduleViewMode(viewMode: string) {
		const nextViewMode = viewMode === 'timeline' ? 'timeline' : 'posts';

		if (postList) {
			postList.dataset.viewChanging = 'true';
		}

		window.requestAnimationFrame(() => {
			currentPage = 1;
			setViewMode(nextViewMode);

			window.requestAnimationFrame(() => {
				if (postList) {
					delete postList.dataset.viewChanging;
				}
			});
		});
	}

	setViewMode(window.localStorage.getItem('postViewMode') ?? 'posts');

	window.addEventListener('post-view-mode-change', (event) => {
		scheduleViewMode(String((event as CustomEvent<string>).detail ?? 'posts'));
	});

	for (const button of pageSizeButtons) {
		button.setAttribute('aria-pressed', String(Number(button.dataset.pageSizeOption) === pageSize));
		button.addEventListener('click', () => {
			pageSize = Number(button.dataset.pageSizeOption ?? '5');
			currentPage = 1;
			window.localStorage.setItem('postPageSize', String(pageSize));

			for (const pageSizeButton of pageSizeButtons) {
				pageSizeButton.setAttribute(
					'aria-pressed',
					String(Number(pageSizeButton.dataset.pageSizeOption) === pageSize),
				);
			}

			applyPostFilters();
		});
	}

	mobilePaginationQuery.addEventListener('change', syncMobilePageSize);

	pagePrev?.addEventListener('click', () => {
		currentPage = Math.max(1, currentPage - 1);
		applyPostFilters();
	});

	pageNext?.addEventListener('click', () => {
		currentPage += 1;
		applyPostFilters();
	});

	if (selectedCategory || selectedTag) {
		currentPage = 1;

		if (filterTitle) {
			filterTitle.hidden = false;
		}

		if (postListTitle) {
			postListTitle.textContent = selectedCategory ?? `#${selectedTag}`;
		}
	}

	function openSearchPanel() {
		if (searchPanel) {
			searchPanel.hidden = false;
		}
		searchInput?.focus();
	}

	window.addEventListener('site-search-open', (event) => {
		event.preventDefault();
		openSearchPanel();
	});

	searchInput?.addEventListener('input', () => {
		searchQuery = searchInput.value.trim().toLowerCase();
		applySearchResults();
	});

	applySearchResults();
	delete document.documentElement.dataset.routeFilterPending;

	if (shouldOpenSearch) {
		openSearchPanel();
	}
</script>

<style>
	.home-post-frame {
		padding: 28px 22px 40px;
		background: rgba(255, 255, 255, 0.18);
		border: 1px solid rgba(255, 255, 255, 0.58);
		border-radius: 20px;
		box-shadow: 0 20px 48px rgba(20, 24, 40, 0.08);
	}

	:global(html[data-route-filter-pending='true']) .home-post-frame {
		opacity: 0;
		pointer-events: none;
	}

	.search-panel {
		margin-bottom: 20px;
	}

	.search-panel[hidden] {
		display: none;
	}

	.home-post-frame:has(.search-panel:not([hidden])) .home-title,
	.home-post-frame:has(.search-panel:not([hidden])) .home-post-list,
	.home-post-frame:has(.search-panel:not([hidden])) .empty-filter,
	.home-post-frame:has(.search-panel:not([hidden])) .pagination {
		display: none;
	}

	.search-title {
		margin: 0 0 14px;
		padding-bottom: 18px;
		border-bottom: 1px solid var(--line);
		font-size: 23px;
		font-weight: 800;
		line-height: 1.25;
	}

	.search-field {
		display: flex;
		align-items: center;
		gap: 10px;
		width: min(450px, 100%);
		height: 42px;
		padding: 0 14px;
		border: 1px solid rgba(255, 255, 255, 0.72);
		border-radius: 20px;
		background: var(--panel-strong);
		box-shadow: var(--shadow);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.search-field:focus-within {
		border-color: color-mix(in srgb, var(--accent) 32%, white);
		box-shadow: 0 14px 32px rgba(45, 84, 255, 0.1);
	}

	.search-field svg {
		width: 16px;
		height: 16px;
		flex: 0 0 auto;
		fill: var(--muted);
	}

	.search-field input {
		width: 100%;
		min-width: 0;
		border: 0;
		background: transparent;
		color: var(--text);
		font-size: 13px;
		outline: 0;
	}

	.search-results {
		display: grid;
		gap: 10px;
		margin-top: 12px;
	}

	.search-results a {
		display: block;
		padding: 18px 20px;
		border-radius: 20px;
		background: #fff;
		color: var(--text);
		text-decoration: none;
		box-shadow: var(--shadow);
		transition:
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.search-results a:hover,
	.search-results a:focus-visible {
		box-shadow: 0 14px 32px rgba(45, 84, 255, 0.1);
		transform: translateY(-1px);
		outline: 0;
	}

	.search-results a[hidden] {
		display: none;
	}

	.search-results strong {
		display: block;
		margin-bottom: 7px;
		font-size: 15px;
		line-height: 1.35;
	}

	.search-results p {
		display: -webkit-box;
		margin: 0 0 12px;
		color: var(--muted);
		font-size: 12px;
		line-height: 1.55;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.search-results :global(mark) {
		padding: 0 2px;
		border-radius: 4px;
		background: color-mix(in srgb, var(--accent) 14%, transparent);
		color: var(--accent);
		font-weight: 700;
	}

	.search-result-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
		color: var(--muted);
		font-size: 11px;
	}

	.search-result-meta span {
		color: var(--muted);
		font-size: 11px;
	}

	.empty-search {
		margin: 12px 0 0;
		color: var(--muted);
		font-size: 13px;
		line-height: 1.6;
	}

	.home-title {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding-bottom: 20px;
		border-bottom: 1px solid var(--line);
		font-size: 23px;
		font-weight: 800;
		line-height: 1.25;
		margin: 0 0 20px;
	}

	.home-title-text {
		display: flex;
		align-items: baseline;
		gap: 8px;
		min-width: 0;
	}

	.home-title[hidden] {
		display: none;
	}

	.home-title strong {
		color: var(--accent);
		font-size: 23px;
	}

	.home-title[data-view-mode='timeline'] .page-size-control {
		display: none;
	}

	.page-size-control {
		display: flex;
		align-items: center;
		gap: 4px;
		height: 34px;
		padding: 3px;
		border: 1px solid rgba(255, 255, 255, 0.58);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.64);
		backdrop-filter: blur(16px);
	}

	.page-size-control button {
		width: 28px;
		height: 28px;
		border: 0;
		border-radius: 50%;
		background: transparent;
		color: var(--muted);
		font-size: 11px;
		font-weight: 700;
		cursor: pointer;
		transition:
			background 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.page-size-control button:hover,
	.page-size-control button:focus-visible,
	.page-size-control button[aria-pressed='true'] {
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		transform: translateY(-1px);
		outline: 0;
	}

	.page-size-control button[aria-pressed='true'] {
		transform: none;
	}

	.home-post-list {
		display: grid;
		gap: 22px;
		margin: 0;
		padding: 0;
		list-style: none;
		transition:
			opacity 120ms ease,
			transform 120ms ease;
	}

	.home-post-list[data-view-changing='true'] {
		opacity: 0.42;
		transform: translateY(3px);
	}

	.home-post-list [hidden] {
		display: none;
	}

	.home-post-list a {
		display: block;
		min-width: 0;
		padding: 22px 20px;
		border: 1px solid rgba(255, 255, 255, 0.82);
		border-radius: 20px;
		background: var(--panel-strong);
		color: var(--text);
		text-decoration: none;
		box-shadow: none;
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.home-post-list a:hover,
	.home-post-list a:focus-visible {
		border-color: color-mix(in srgb, var(--accent) 24%, white);
		box-shadow: 0 12px 30px rgba(45, 84, 255, 0.08);
		transform: translateY(-1px);
		outline: 0;
