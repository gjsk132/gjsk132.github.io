---
import Layout from '../layouts/Layout.astro';
import { formatPostDate, getAllPosts } from '../lib/posts';

const posts = await getAllPosts();
---

<Layout title="gjsk132 blog" description="gjsk132's blog">
	<main class="home">
		<header class="intro">
			<p class="eyebrow">gjsk132.github.io</p>
			<h1>기록을 차곡차곡 쌓는 블로그</h1>
			<p class="summary">
				Obsidian의 Markdown 글을 Astro가 읽어 GitHub Pages에 정적 사이트로 배포합니다.
			</p>
		</header>

		<section class="posts" aria-labelledby="posts-title">
			<div class="section-header">
				<h2 id="posts-title">최근 글</h2>
				<a href="/blog/">전체 보기</a>
			</div>

			{
				posts.length > 0 ? (
					<ul>
						{posts.slice(0, 5).map((post) => (
							<li>
								<a href={`/blog/${post.slug}/`}>
									<span>{post.frontmatter.title ?? post.slug}</span>
									{post.frontmatter.pubDate && (
										<time datetime={new Date(post.frontmatter.pubDate).toISOString()}>
											{formatPostDate(post.frontmatter.pubDate)}
										</time>
									)}
								</a>
							</li>
						))}
					</ul>
				) : (
					<p class="empty">아직 등록된 글이 없습니다. content/post 폴더에 Markdown 파일을 추가해 주세요.</p>
				)
			}
		</section>
	</main>
</Layout>

<style>
	.home {
		width: min(880px, calc(100% - 32px));
		margin: 0 auto;
		padding: 72px 0;
	}

	.intro {
		padding-bottom: 40px;
		border-bottom: 1px solid #d9ded8;
	}

	.eyebrow {
		margin: 0 0 14px;
		color: #51604f;
		font-size: 14px;
		font-weight: 700;
	}

	h1 {
		max-width: 720px;
		margin: 0;
		color: #172018;
		font-size: 48px;
		line-height: 1.12;
	}

	.summary {
		max-width: 620px;
		margin: 20px 0 0;
		color: #4c5a50;
		font-size: 18px;
		line-height: 1.7;
	}

	.posts {
		padding-top: 36px;
	}

	.section-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		margin-bottom: 16px;
	}

	h2 {
		margin: 0;
		font-size: 22px;
	}

	.section-header a {
		color: #315f4d;
		font-weight: 700;
		text-decoration: none;
	}

	ul {
		display: grid;
		gap: 10px;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	li a {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding: 18px 0;
		border-bottom: 1px solid #e3e6e1;
		text-decoration: none;
	}

	li span {
		font-size: 18px;
		font-weight: 700;
	}

	time {
		flex: 0 0 auto;
		color: #66736b;
		font-size: 14px;
	}

	.empty {
		margin: 0;
		padding: 24px 0;
		color: #66736b;
		line-height: 1.7;
	}

	@media (max-width: 640px) {
		.home {
			padding: 48px 0;
		}

		h1 {
			font-size: 34px;
		}

		li a {
			align-items: flex-start;
			flex-direction: column;
			gap: 6px;
		}
	}
</style>
