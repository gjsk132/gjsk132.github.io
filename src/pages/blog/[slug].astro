---
import Layout from '../../layouts/Layout.astro';
import { formatPostDate, getAllPosts } from '../../lib/posts';

export async function getStaticPaths() {
	const posts = await getAllPosts();

	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = post;
const title = post.frontmatter.title ?? post.slug;
---

<Layout title={`${title} | gjsk132 blog`} description={post.frontmatter.description ?? title}>
	<main class="post">
		<nav>
			<a href="/blog/">글 목록</a>
		</nav>

		<article>
			<header>
				<h1>{title}</h1>
				{
					post.frontmatter.pubDate && (
						<time datetime={new Date(post.frontmatter.pubDate).toISOString()}>
							{formatPostDate(post.frontmatter.pubDate)}
						</time>
					)
				}
				{post.frontmatter.description && <p>{post.frontmatter.description}</p>}
			</header>

			<div class="content">
				<Content />
			</div>
		</article>
	</main>
</Layout>

<style>
	.post {
		width: min(760px, calc(100% - 32px));
		margin: 0 auto;
		padding: 56px 0 72px;
	}

	nav {
		margin-bottom: 32px;
	}

	nav a {
		color: #315f4d;
		font-weight: 700;
		text-decoration: none;
	}

	header {
		margin-bottom: 36px;
		padding-bottom: 28px;
		border-bottom: 1px solid #dfe4dd;
	}

	h1 {
		margin: 0 0 14px;
		color: #172018;
		font-size: 42px;
		line-height: 1.2;
	}

	time {
		display: block;
		color: #66736b;
		font-size: 14px;
	}

	header p {
		margin: 18px 0 0;
		color: #4c5a50;
		font-size: 18px;
		line-height: 1.7;
	}

	.content {
		color: #1f2933;
		font-size: 18px;
		line-height: 1.85;
	}

	.content :global(h2) {
		margin: 2em 0 0.6em;
		color: #172018;
		font-size: 28px;
		line-height: 1.3;
	}

	.content :global(h3) {
		margin: 1.8em 0 0.5em;
		color: #172018;
		font-size: 22px;
		line-height: 1.35;
	}

	.content :global(p) {
		margin: 1em 0;
	}

	.content :global(a) {
		color: #315f4d;
		font-weight: 700;
	}

	.content :global(img) {
		display: block;
		max-width: 100%;
		height: auto;
		margin: 28px auto;
		border-radius: 8px;
	}

	.content :global(pre) {
		overflow-x: auto;
		padding: 16px;
		border-radius: 8px;
		background: #18201b;
		color: #eef3ec;
	}

	.content :global(code) {
		font-size: 0.92em;
	}

	.content :global(:not(pre) > code) {
		padding: 2px 5px;
		border-radius: 5px;
		background: #e9eee7;
	}

	@media (max-width: 640px) {
		h1 {
			font-size: 34px;
		}

		.content {
			font-size: 17px;
		}
	}
</style>
