---
import BlogLayout from '../../components/BlogLayout.astro';
import WikiTermHighlighter from '../../components/WikiTermHighlighter.astro';
import Layout from '../../layouts/Layout.astro';
import { getAllWikiEntries } from '../../lib/wikiEntries';
import {
	formatPostDate,
	getAllPosts,
	getPostCategories,
	getPostCategoryCounts,
	getPostDate,
	getPostTags,
} from '../../lib/posts';

export async function getStaticPaths() {
	const posts = await getAllPosts();

	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = post;
const title = post.frontmatter.title ?? post.slug;
const posts = await getAllPosts();
const categories = getPostCategories(posts);
const categoryCounts = getPostCategoryCounts(posts);
const tags = getPostTags(posts);
const postCategory = post.frontmatter.category ?? post.frontmatter.categories?.[0] ?? 'none';
const postTags = post.frontmatter.tags ?? [];
const postDescription = post.frontmatter.description ?? post.frontmatter.summary;
const postDate = getPostDate(post);
const wikiEntries = await getAllWikiEntries();
const currentPostIndex = posts.findIndex((item) => item.slug === post.slug);
const nextPost = currentPostIndex > 0 ? posts[currentPostIndex - 1] : undefined;
const previousPost =
	currentPostIndex >= 0 && currentPostIndex < posts.length - 1 ? posts[currentPostIndex + 1] : undefined;

function navPostCategory(navPost: (typeof posts)[number]) {
	return navPost.frontmatter.category ?? navPost.frontmatter.categories?.[0] ?? 'none';
}

function navPostTags(navPost: (typeof posts)[number]) {
	return navPost.frontmatter.tags ?? [];
}
---

<Layout title={`${title} | gjsk132 blog`} description={post.frontmatter.description ?? title}>
	<BlogLayout
		categories={categories}
		categoryCounts={categoryCounts}
		tags={tags}
		postCount={posts.length}
		activeCategory={postCategory}
		activeTags={postTags}
	>
		<article class="post-card">
			<WikiTermHighlighter entries={wikiEntries} targetSelector=".article-content" />
			{postDate && <time class="post-date" datetime={new Date(postDate).toISOString()}>{formatPostDate(postDate)}</time>}
			<h1>{title}</h1>
			{postDescription && <p class="post-description">{postDescription}</p>}
			<div class="meta">
				<span>{postCategory}</span>
				{
					postTags.length > 0 && (
						<div class="post-tags">
							{postTags.map((tag) => <em>{tag}</em>)}
						</div>
					)
				}
			</div>

			<hr class="content-divider" />

			<div class="article-content">
				<Content />
			</div>
		</article>

		{
			(previousPost || nextPost) && (
				<nav class="post-neighbors" aria-label="이전 다음 게시글">
					{previousPost ? (
						<a href={`/blog/${previousPost.slug}/`} rel="prev" data-astro-prefetch>
							<span>이전 게시글</span>
							<strong>{previousPost.frontmatter.title ?? previousPost.slug}</strong>
							<div class="neighbor-meta">
								<em>{navPostCategory(previousPost)}</em>
								{navPostTags(previousPost).map((tag) => <em>{tag}</em>)}
							</div>
						</a>
					) : null}
					{nextPost ? (
						<a href={`/blog/${nextPost.slug}/`} rel="next" data-astro-prefetch>
							<span>다음 게시글</span>
							<strong>{nextPost.frontmatter.title ?? nextPost.slug}</strong>
							<div class="neighbor-meta">
								<em>{navPostCategory(nextPost)}</em>
								{navPostTags(nextPost).map((tag) => <em>{tag}</em>)}
							</div>
						</a>
					) : null}
				</nav>
			)
		}
	</BlogLayout>
</Layout>

<script>
	function getCodeLanguage(pre: HTMLPreElement) {
		const languageFromData = pre.dataset.language;
		const code = pre.querySelector('code');
		const languageFromClass = Array.from(code?.classList ?? [])
			.find((className) => className.startsWith('language-'))
			?.replace('language-', '');

		return languageFromData ?? languageFromClass ?? 'code';
	}

	function isMermaidPre(pre: HTMLPreElement) {
		return getCodeLanguage(pre).trim().toLowerCase() === 'mermaid';
	}

	function enhanceCodeBlocks() {
		document.querySelectorAll<HTMLPreElement>('.article-content pre').forEach((pre) => {
			if (isMermaidPre(pre) || pre.closest('.code-block')) return;

			const wrapper = document.createElement('div');
			const header = document.createElement('div');
			const language = document.createElement('span');
			const button = document.createElement('button');
			const code = pre.querySelector('code');

			wrapper.className = 'code-block';
			header.className = 'code-block-header';
			language.className = 'code-language';
			language.textContent = getCodeLanguage(pre);
			button.className = 'code-copy-button';
			button.type = 'button';
			button.innerHTML =
				'<svg aria-hidden="true" viewBox="0 0 24 24"><path d="M8 7.5A2.5 2.5 0 0 1 10.5 5h6A2.5 2.5 0 0 1 19 7.5v9a2.5 2.5 0 0 1-2.5 2.5h-6A2.5 2.5 0 0 1 8 16.5v-9Zm2 0v9c0 .3.2.5.5.5h6c.3 0 .5-.2.5-.5v-9c0-.3-.2-.5-.5-.5h-6c-.3 0-.5.2-.5.5ZM5 14.5V6a3 3 0 0 1 3-3h6.5v2H8a1 1 0 0 0-1 1v8.5H5Z" /></svg>';
			button.setAttribute('aria-label', '코드 복사');
			button.title = '코드 복사';

			button.addEventListener('click', async () => {
				const codeText = code?.textContent ?? pre.textContent ?? '';

				try {
					await navigator.clipboard.writeText(codeText);
					button.dataset.copied = 'true';
					button.setAttribute('aria-label', '복사됨');
					button.title = '복사됨';
					window.setTimeout(() => {
						delete button.dataset.copied;
						button.setAttribute('aria-label', '코드 복사');
						button.title = '코드 복사';
					}, 1200);
				} catch {
					button.dataset.failed = 'true';
					button.setAttribute('aria-label', '복사 실패');
					button.title = '복사 실패';
					window.setTimeout(() => {
						delete button.dataset.failed;
						button.setAttribute('aria-label', '코드 복사');
						button.title = '코드 복사';
					}, 1200);
				}
			});

			header.append(language, button);
			pre.before(wrapper);
			wrapper.append(header, pre);
		});
	}

	function setupImageZoom() {
		const images = document.querySelectorAll<HTMLImageElement>('.article-content img');
		if (images.length === 0) return;

		let overlay: HTMLDivElement | null = null;

		function onKeydown(event: KeyboardEvent) {
			if (event.key === 'Escape') close();
		}

		function close() {
			if (!overlay) return;
			const current = overlay;
			overlay = null;
			current.classList.remove('is-open');
			document.removeEventListener('keydown', onKeydown);
			window.setTimeout(() => current.remove(), 200);
		}

		function open(src: string, alt: string) {
			overlay = document.createElement('div');
			overlay.className = 'image-lightbox';

			const enlarged = document.createElement('img');
			enlarged.src = src;
			enlarged.alt = alt;

			overlay.append(enlarged);
			overlay.addEventListener('click', close);
			document.body.append(overlay);
			document.addEventListener('keydown', onKeydown);

			window.requestAnimationFrame(() => overlay?.classList.add('is-open'));
		}

		images.forEach((image) => {
			image.addEventListener('click', () => open(image.currentSrc || image.src, image.alt));
		});
	}

	function scheduleMermaidRender(callback: () => void) {
		if ('requestIdleCallback' in window) {
			window.requestIdleCallback(callback, { timeout: 1200 });
			return;
		}

		window.setTimeout(callback, 1);
	}

	enhanceCodeBlocks();
	setupImageZoom();

	scheduleMermaidRender(async () => {
		const mermaidBlocks = document.querySelectorAll<HTMLElement>(
			'.article-content pre[data-language="mermaid"] > code, .article-content pre > code.language-mermaid',
		);

		if (mermaidBlocks.length === 0) return;

		const { default: mermaid } = await import('mermaid');

		mermaid.initialize({
			startOnLoad: false,
			theme: 'default',
			securityLevel: 'strict',
		});

		for (const block of mermaidBlocks) {
			const pre = block.parentElement;
			if (!pre) continue;

			const container = document.createElement('div');
			container.className = 'mermaid';
			container.textContent = block.textContent ?? '';
			pre.replaceWith(container);
		}

		const renderedMermaidBlocks = document.querySelectorAll<HTMLElement>('.article-content .mermaid');

		await mermaid.run({ nodes: renderedMermaidBlocks });
	});
</script>

<style>
	.post-card {
		padding: 40px;
		background: var(--panel);
		border-radius: 24px;
		box-shadow: 0 20px 48px rgba(20, 24, 40, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.9);
	}

	.post-date {
		display: block;
		margin: 0 0 8px;
		color: var(--muted);
		font-size: 13px;
		line-height: 1.4;
	}

	h1 {
		font-size: 34px;
		line-height: 1.25;
		margin: 0 0 10px;
		overflow-wrap: anywhere;
	}

	.post-description {
		margin: 0 0 18px;
		color: var(--muted);
		font-size: 14px;
		line-height: 1.7;
	}

	.meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
		min-width: 0;
		color: var(--muted);
		font-size: 13px;
		margin-bottom: 34px;
	}

	.meta span {
		max-width: 100%;
		padding: 4px 8px;
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		font-weight: 700;
		overflow-wrap: anywhere;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		min-width: 0;
	}

	.post-tags em {
		max-width: 100%;
		padding: 4px 8px;
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		font-size: 11px;
		font-style: normal;
		font-weight: 700;
		overflow-wrap: anywhere;
	}

	.content-divider {
		height: 1px;
		margin: 0 0 28px;
		border: 0;
		background: var(--line);
	}

	.article-content {
		font-size: 14px;
	}

	.article-content :global(h2) {
		margin-top: 34px;
		font-size: 20px;
	}

	.article-content :global(h3) {
		margin-top: 26px;
		font-size: 17px;
	}

	.article-content :global(p),
	.article-content :global(li) {
		line-height: 1.75;
	}

	.article-content :global(a) {
		color: var(--accent);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition:
			color 160ms ease,
			text-decoration-color 160ms ease;
	}

	.article-content :global(a:hover),
	.article-content :global(a:focus-visible) {
		color: color-mix(in srgb, var(--accent) 78%, black);
		text-decoration-color: currentColor;
		outline: 0;
	}

	.article-content :global(img) {
		display: block;
		max-width: 100%;
		height: auto;
		border-radius: 16px;
		cursor: zoom-in;
	}

	:global(.image-lightbox) {
		position: fixed;
		inset: 0;
		z-index: 1000;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 24px;
		background: rgba(10, 12, 20, 0.85);
		cursor: zoom-out;
		opacity: 0;
		transition: opacity 0.2s ease;
	}

	:global(.image-lightbox.is-open) {
		opacity: 1;
	}

	:global(.image-lightbox img) {
		max-width: 100%;
		max-height: 100%;
		border-radius: 12px;
		box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
	}

	.article-content :global(table) {
		display: block;
		width: max-content;
		max-width: 100%;
		margin: 22px 0;
		overflow-x: auto;
		border: 1px solid var(--line);
		border-radius: 12px;
		border-spacing: 0;
		font-size: 13.5px;
	}

	.article-content :global(th),
	.article-content :global(td) {
		padding: 9px 14px;
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		text-align: left;
		vertical-align: top;
		line-height: 1.65;
		overflow-wrap: anywhere;
	}

	.article-content :global(th:last-child),
	.article-content :global(td:last-child) {
		border-right: 0;
	}

	.article-content :global(tbody tr:last-child td) {
		border-bottom: 0;
	}

	.article-content :global(thead th) {
		background: color-mix(in srgb, var(--accent) 8%, white);
		font-weight: 700;
		color: var(--text);
	}

	.article-content :global(tbody tr:nth-child(even)) {
		background: color-mix(in srgb, var(--accent) 3.5%, white);
	}

	.article-content :global(pre) {
		overflow-x: auto;
		margin: 22px 0;
		padding: 18px;
		border-radius: 16px;
		background: color-mix(in srgb, var(--accent) 8%, #05070d) !important;
		border: 1px solid color-mix(in srgb, var(--accent) 18%, rgba(255, 255, 255, 0.1));
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.article-content :global(.code-block) {
		position: relative;
		margin: 22px 0;
		border-radius: 10px;
		background: color-mix(in srgb, var(--accent) 8%, #05070d);
		border: 1px solid color-mix(in srgb, var(--accent) 18%, rgba(255, 255, 255, 0.1));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.08),
			inset 0 0 0 999px rgba(67, 97, 255, 0.02),
			0 16px 34px rgba(20, 24, 40, 0.08);
		overflow: hidden;
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.article-content :global(.code-block:hover) {
		border-color: color-mix(in srgb, var(--accent) 54%, rgba(255, 255, 255, 0.14));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.1),
			inset 0 0 0 999px rgba(67, 97, 255, 0.032),
			0 18px 38px rgba(20, 24, 40, 0.1);
	}

	.article-content :global(.code-block pre) {
		margin: 0;
		padding: 18px 18px 20px;
		border: 0;
		border-radius: 0;
		background: transparent !important;
		box-shadow: none;
	}

	.article-content :global(.code-block pre:hover) {
		border-color: transparent;
		box-shadow: none;
	}

	.article-content :global(.code-block-header) {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		height: 34px;
		padding: 0 10px 0 66px;
		background: color-mix(in srgb, var(--accent) 10%, #02040a);
		border-bottom: 1px solid color-mix(in srgb, var(--accent) 20%, rgba(255, 255, 255, 0.1));
		pointer-events: none;
	}

	.article-content :global(.code-block-header::before) {
		content: '';
		position: absolute;
		left: 16px;
		top: 50%;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: color-mix(in srgb, var(--accent) 26%, #30363d);
		box-shadow:
			12px 0 0 color-mix(in srgb, var(--accent) 26%, #30363d),
			24px 0 0 color-mix(in srgb, var(--accent) 26%, #30363d);
		transform: translateY(-50%);
	}

	.article-content :global(.code-language) {
		color: color-mix(in srgb, var(--accent) 42%, #d6e2ff);
		font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, monospace;
		font-size: 10px;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.article-content :global(.code-copy-button) {
		pointer-events: auto;
		width: 28px;
		height: 28px;
		display: grid;
		place-items: center;
		padding: 0;
		border: 1px solid color-mix(in srgb, var(--accent) 20%, rgba(255, 255, 255, 0.12));
		border-radius: 8px;
		background: color-mix(in srgb, var(--accent) 8%, #0b0f15);
		color: color-mix(in srgb, var(--accent) 14%, #8b949e);
		cursor: pointer;
		transition:
			background 160ms ease,
			border-color 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.article-content :global(.code-copy-button svg) {
		width: 16px;
		height: 16px;
		fill: currentColor;
	}

	.article-content :global(.code-copy-button:hover),
	.article-content :global(.code-copy-button:focus-visible) {
		border-color: color-mix(in srgb, var(--accent) 46%, rgba(255, 255, 255, 0.14));
		background: color-mix(in srgb, var(--accent) 24%, #0d1117);
		color: #dbe7ff;
		transform: translateY(-1px);
		outline: 0;
	}

	.article-content :global(.code-copy-button[data-copied='true']) {
		border-color: rgba(32, 143, 81, 0.28);
		background: rgba(32, 143, 81, 0.1);
		color: #208f51;
	}

	.article-content :global(.code-copy-button[data-failed='true']) {
		border-color: rgba(210, 55, 55, 0.28);
		background: rgba(210, 55, 55, 0.1);
		color: #d23737;
	}

	.article-content :global(pre:hover) {
		border-color: rgba(67, 97, 255, 0.34);
		box-shadow: 0 12px 28px rgba(20, 24, 40, 0.06);
	}

	.article-content :global(pre[data-language='mermaid']),
	.article-content :global(pre:has(> code.language-mermaid)) {
		position: relative;
		min-height: 120px;
		overflow: hidden;
		margin: 24px 0;
		background: var(--panel-strong) !important;
		border: 1px solid var(--line);
		color: transparent;
		user-select: none;
	}

	.article-content :global(pre[data-language='mermaid'] code),
	.article-content :global(pre:has(> code.language-mermaid) code) {
		opacity: 0;
	}

	.article-content :global(pre[data-language='mermaid']::before),
	.article-content :global(pre:has(> code.language-mermaid)::before) {
		content: '';
		position: absolute;
		inset: 16px;
		border-radius: 12px;
		background:
			linear-gradient(90deg, transparent, rgba(67, 97, 255, 0.08), transparent),
			color-mix(in srgb, var(--accent) 4%, white);
	}

	.article-content :global(code) {
		font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, monospace;
	}

	.article-content
		:global(:where(p, li, dd, dt, blockquote, figcaption, td, th, h1, h2, h3, h4, h5, h6) code) {
		display: inline-block;
		max-width: 100%;
		padding: 0.08em 0.42em 0.1em;
		border: 0;
		border-radius: 6px;
		background: color-mix(in srgb, var(--accent) 8%, white);
		color: color-mix(in srgb, var(--accent) 72%, #111);
		font-size: 0.92em;
		font-weight: 650;
		line-height: 1.45;
		vertical-align: 0.02em;
		overflow-wrap: anywhere;
	}

	.article-content :global(.mermaid) {
		display: flex;
		justify-content: center;
		overflow-x: auto;
		margin: 24px 0;
		padding: 16px;
		border-radius: 16px;
		background: var(--panel-strong);
		border: 1px solid var(--line);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.article-content :global(.mermaid:hover) {
		border-color: color-mix(in srgb, var(--accent) 18%, var(--line));
		box-shadow: 0 12px 28px rgba(20, 24, 40, 0.06);
	}

	.article-content :global(.mermaid svg) {
		max-width: 100%;
		height: auto;
	}

	.post-neighbors {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
		margin-top: 16px;
		padding: 16px;
		border: 1px solid rgba(255, 255, 255, 0.58);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.18);
		box-shadow: 0 20px 48px rgba(20, 24, 40, 0.08);
	}

	.post-neighbors a {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 9px;
		min-width: 0;
		min-height: 118px;
		padding: 18px;
		border: 1px solid rgba(255, 255, 255, 0.82);
		border-radius: 18px;
		background: var(--panel-strong);
		color: var(--text);
		text-decoration: none;
		width: 100%;
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.post-neighbors a:hover,
	.post-neighbors a:focus-visible {
		border-color: color-mix(in srgb, var(--accent) 24%, white);
		box-shadow: 0 12px 30px rgba(45, 84, 255, 0.08);
		transform: translateY(-1px);
		outline: 0;
	}

	.post-neighbors a[rel='next'] {
		align-items: flex-end;
		text-align: right;
	}

	.post-neighbors span {
		color: var(--muted);
		font-size: 12px;
		font-weight: 700;
	}

	.post-neighbors strong {
		width: 100%;
		min-width: 0;
		color: var(--text);
		font-size: 15px;
		line-height: 1.4;
		overflow-wrap: anywhere;
	}

	.neighbor-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 6px;
		width: 100%;
		min-width: 0;
	}

	.post-neighbors em {
		max-width: 100%;
		padding: 4px 8px;
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		font-size: 11px;
		font-style: normal;
