---
interface Props {
	categories?: string[];
	categoryCounts?: Record<string, number>;
	tags?: string[];
	postCount?: number;
	activeCategory?: string;
	activeTags?: string[];
}

const {
	categories = [],
	categoryCounts = {},
	tags = [],
	activeCategory,
	activeTags = [],
} = Astro.props;

function categoryHref(category: string) {
	return `/?category=${encodeURIComponent(category)}`;
}

function tagHref(tag: string) {
	return `/?tag=${encodeURIComponent(tag)}`;
}

function isActiveCategory(category: string) {
	return activeCategory === category;
}

function isActiveTag(tag: string) {
	return activeTags.includes(tag);
}
---

<div class="blog-layout">
	<a class="blog-home-button" href="/" aria-label="홈으로 이동" title="Home" data-home-button>
		<svg aria-hidden="true" viewBox="0 0 24 24">
			<path d="M12 4.2 5.1 9.7c-.5.4-.8 1-.8 1.7v5.7c0 1 .8 1.8 1.8 1.8h3.2v-4.3c0-.8.6-1.4 1.4-1.4h2.6c.8 0 1.4.6 1.4 1.4v4.3h3.2c1 0 1.8-.8 1.8-1.8v-5.7c0-.7-.3-1.3-.8-1.7L12 4.2Z" />
		</svg>
	</a>

	<div class="top-tools">
		<button class="search-button" type="button" aria-label="검색 열기" title="검색" data-search-open>
			<svg aria-hidden="true" viewBox="0 0 24 24">
				<path d="m20.7 19.3-4.2-4.2a7 7 0 1 0-1.4 1.4l4.2 4.2 1.4-1.4ZM5 11a6 6 0 1 1 12 0 6 6 0 0 1-12 0Z" />
			</svg>
		</button>
		<div class="view-toggle" role="group" aria-label="보기 형태">
			<button type="button" data-view-button="posts" aria-label="게시글 형태" title="게시글 형태" aria-pressed="true">
				<svg aria-hidden="true" viewBox="0 0 24 24">
					<path d="M5 5.5A2.5 2.5 0 0 1 7.5 3h9A2.5 2.5 0 0 1 19 5.5v13A2.5 2.5 0 0 1 16.5 21h-9A2.5 2.5 0 0 1 5 18.5v-13Zm2 0v13c0 .3.2.5.5.5h9c.3 0 .5-.2.5-.5v-13c0-.3-.2-.5-.5-.5h-9c-.3 0-.5.2-.5.5Zm2 2h6v2H9v-2Zm0 4h6v2H9v-2Zm0 4h4v2H9v-2Z" />
				</svg>
			</button>
			<button type="button" data-view-button="timeline" aria-label="타임라인 형태" title="타임라인 형태" aria-pressed="false">
				<svg aria-hidden="true" viewBox="0 0 24 24">
					<path d="M11 4h2v3.1a4 4 0 0 1 0 7.8V20h-2v-5.1a4 4 0 0 1 0-7.8V4Zm1 5a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm5-5h3v2h-3V4Zm0 5h5v2h-5V9Zm0 5h3v2h-3v-2Zm0 5h5v2h-5v-2ZM2 9h5v2H2V9Zm2-5h3v2H4V4Zm0 15h3v2H4v-2Z" />
				</svg>
			</button>
		</div>
		<slot name="top-tools" />
	</div>

	<aside class="sidebar">
		<section class="sidebar-frame profile-frame">
			<div class="profile-card">
				<div class="avatar">g</div>
				<div>
					<strong>gjsk132</strong>
					<p>나만의 지식 저장소</p>
				</div>
			</div>

			<a class="github-card" href="https://github.com/gjsk132">GitHub 바로가기</a>
		</section>

		<section class="sidebar-frame plain-card">
			<h3>Category</h3>
			<div class="category-list">
				{
					categories.map((category) => (
						<a
							href={categoryHref(category)}
							data-category-link={category}
							aria-current={isActiveCategory(category) ? 'page' : undefined}
						>
							<span>{category}</span>
							<strong>{categoryCounts[category] ?? 0}</strong>
						</a>
					))
				}
			</div>
		</section>

		<section class="sidebar-frame plain-card">
			<h3>Tag</h3>
			<div class="tags">
				{
					tags.length > 0 ? (
						tags.map((tag) => (
							<a href={tagHref(tag)} data-tag-link={tag} aria-current={isActiveTag(tag) ? 'page' : undefined}>
								{tag}
							</a>
						))
					) : (
						<p class="empty-side">Obsidian frontmatter에 tags를 추가하면 표시됩니다.</p>
					)
				}
			</div>
		</section>
	</aside>

	<main class="content">
		<slot />
	</main>
</div>

<script>
	const homeButton = document.querySelector('[data-home-button]');
	const searchParams = new URLSearchParams(window.location.search);
	const selectedCategory = searchParams.get('category');
	const selectedTag = searchParams.get('tag');
	const searchOpenButton = document.querySelector<HTMLButtonElement>('[data-search-open]');

	homeButton?.addEventListener('click', (event) => {
		if (window.location.pathname === '/' && !window.location.search) {
			event.preventDefault();
		}
	});

	if (selectedCategory || selectedTag) {
		document.querySelectorAll<HTMLElement>('[data-category-link]').forEach((link) => {
			if (link.dataset.categoryLink === selectedCategory) {
				link.setAttribute('aria-current', 'page');
			} else {
				link.removeAttribute('aria-current');
			}
		});

		document.querySelectorAll<HTMLElement>('[data-tag-link]').forEach((link) => {
			if (link.dataset.tagLink === selectedTag) {
				link.setAttribute('aria-current', 'page');
			} else {
				link.removeAttribute('aria-current');
			}
		});
	}

	searchOpenButton?.addEventListener('click', () => {
		const openEvent = new CustomEvent('site-search-open', { cancelable: true });
		const wasHandled = !window.dispatchEvent(openEvent);
		if (!wasHandled && window.location.pathname !== '/') {
			window.location.href = '/?search=1';
		}
	});

	const savedViewMode = window.localStorage.getItem('postViewMode') ?? 'posts';

	document.querySelectorAll<HTMLButtonElement>('[data-view-button]').forEach((button) => {
		button.setAttribute('aria-pressed', String(button.dataset.viewButton === savedViewMode));
	});

	document.querySelectorAll<HTMLButtonElement>('[data-view-button]').forEach((button) => {
		button.addEventListener('click', () => {
			if (window.location.pathname === '/') return;

			window.localStorage.setItem('postViewMode', button.dataset.viewButton ?? 'posts');
			window.location.href = '/';
		});
	});
</script>

<style>
	.blog-layout {
		min-height: 100vh;
		width: min(1080px, 98%);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 244px minmax(0, 1fr);
		grid-template-areas: 'sidebar content';
		align-items: start;
		gap: 24px;
		padding: 66px 0 0;
		background: transparent;
	}

	.blog-home-button {
		position: fixed;
		top: 18px;
		left: calc(max(1vw, (100vw - 1080px) / 2) + 20px);
		z-index: 10;
		width: 32px;
		height: 32px;
		display: grid;
		place-items: center;
		border: 1px solid rgba(255, 255, 255, 0.75);
		border-radius: 50%;
		background: var(--panel);
		box-shadow: var(--shadow);
		color: var(--text);
		text-decoration: none;
		backdrop-filter: blur(16px);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.blog-home-button:hover,
	.blog-home-button:focus-visible {
		border-color: color-mix(in srgb, var(--accent) 32%, white);
		color: var(--accent);
		box-shadow: 0 12px 26px rgba(45, 84, 255, 0.12);
		transform: translateY(-1px);
		outline: 0;
	}

	.blog-home-button svg {
		width: 17px;
		height: 17px;
		fill: currentColor;
	}

	.top-tools {
		position: fixed;
		top: 18px;
		right: max(24px, calc((100vw - 1080px) / 2));
		z-index: 10;
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.search-button {
		width: 34px;
		height: 34px;
		display: grid;
		place-items: center;
		border: 1px solid rgba(255, 255, 255, 0.5);
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.64);
		color: var(--text);
		cursor: pointer;
		backdrop-filter: blur(16px);
		transition:
			background 160ms ease,
			color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.search-button:hover,
	.search-button:focus-visible {
		background: #fff;
		color: var(--accent);
		box-shadow: 0 12px 26px rgba(45, 84, 255, 0.12);
		transform: translateY(-1px);
		outline: 0;
	}

	.search-button svg {
		width: 18px;
		height: 18px;
		fill: currentColor;
	}

	.top-tools :global(.view-toggle) {
		display: flex;
		align-items: center;
		gap: 4px;
		height: 34px;
		padding: 3px;
		border: 1px solid rgba(255, 255, 255, 0.58);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.64);
		backdrop-filter: blur(16px);
	}

	.top-tools :global(.view-toggle button) {
		width: 28px;
		height: 28px;
		display: grid;
		place-items: center;
		border: 0;
		border-radius: 50%;
		background: transparent;
		color: var(--muted);
		cursor: pointer;
		transition:
			background 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.top-tools :global(.view-toggle button:hover),
	.top-tools :global(.view-toggle button:focus-visible) {
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		color: var(--accent);
		transform: translateY(-1px);
		outline: 0;
	}

	.top-tools :global(.view-toggle button[aria-pressed='true']) {
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
	}

	.top-tools :global(.view-toggle svg) {
		width: 18px;
		height: 18px;
		fill: currentColor;
	}

	.sidebar {
		grid-area: sidebar;
		position: sticky;
		top: 66px;
		display: flex;
		flex-direction: column;
		gap: 14px;
		overflow-y: auto;
		padding: 0;
		background: transparent;
	}

	.sidebar-frame {
		padding: 14px;
		border: 2px solid rgba(255, 255, 255, 0.58);
		border-radius: 20px;
		background: rgba(255, 255, 255, 0.18);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
	}

	.profile-card,
	.github-card {
		background: #fff;
		border: 1px solid rgba(255, 255, 255, 0.9);
		border-radius: 20px;
		box-shadow: 0 14px 32px rgba(20, 24, 40, 0.07);
	}

	.profile-card {
		display: flex;
		align-items: center;
		gap: 12px;
		min-height: 76px;
		padding: 14px 16px;
		margin-bottom: 14px;
	}

	.avatar {
		width: 42px;
		height: 42px;
		border-radius: 50%;
		display: grid;
		place-items: center;
		background: var(--panel-strong);
		border: 1px solid var(--line);
		color: var(--muted);
		font-weight: 700;
	}

	.profile-card strong {
		display: block;
		margin-bottom: 4px;
	}

	.profile-card p {
		margin: 0;
		color: var(--muted);
		font-size: 12px;
	}

	.github-card {
		display: block;
		min-height: 38px;
		padding: 11px 8px;
		text-align: center;
		text-decoration: none;
		font-size: 13px;
		transition:
			box-shadow 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.github-card:hover,
	.github-card:focus-visible {
		color: var(--accent);
		box-shadow: 0 16px 34px rgba(45, 84, 255, 0.11);
		transform: translateY(-1px);
		outline: 0;
	}

	.category-list {
		display: grid;
		gap: 10px;
	}

	.category-list a {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		width: 100%;
		padding: 10px 13px;
		border-radius: 999px;
		background: #fff;
		color: var(--text);
		font-size: 12px;
		text-decoration: none;
		transition:
			background 160ms ease,
			color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.category-list a:hover,
	.category-list a:focus-visible,
	.tags a:hover,
	.tags a:focus-visible {
		background: color-mix(in srgb, var(--accent) 8%, white);
		color: var(--accent);
		box-shadow: 0 10px 22px rgba(45, 84, 255, 0.08);
		transform: translateY(-1px);
		outline: 0;
	}

	.category-list a[aria-current='page'],
	.tags a[aria-current='page'] {
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		font-weight: 700;
	}

	.category-list strong {
		color: var(--accent);
		font-size: 12px;
	}

	.empty-side {
		margin: 0;
		color: var(--muted);
		font-size: 12px;
		line-height: 1.6;
	}

	.plain-card {
		display: block;
	}

	.plain-card h3 {
		margin: 0 0 10px;
		font-size: 14px;
		font-weight: 700;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.tags span,
	.tags a {
		padding: 7px 10px;
		border-radius: 999px;
		background: #fff;
		color: var(--text);
		font-size: 12px;
		text-decoration: none;
	}

	.tags a {
		transition:
			background 160ms ease,
			color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.content {
		grid-area: content;
		max-width: none;
		width: 100%;
		min-width: 0;
	}

	@media (max-width: 900px) {
		.blog-layout {
			width: auto;
			grid-template-columns: 1fr;
			grid-template-areas:
				'sidebar'
				'content';
			padding: 70px 14px 32px;
		}

		.blog-home-button {
			left: 18px;
			top: 18px;
		}

		.top-tools {
			left: 72px;
			right: 16px;
			top: 20px;
		}

		.sidebar {
			position: static;
			height: auto;
		}
	}
</style>
