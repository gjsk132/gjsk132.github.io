---
interface Props {
	categories?: string[];
	categoryCounts?: Record<string, number>;
	tags?: string[];
	postCount?: number;
	activeCategory?: string;
	activeTags?: string[];
}

const {
	categories = [],
	categoryCounts = {},
	tags = [],
	activeCategory,
	activeTags = [],
} = Astro.props;
const selectedCategory = Astro.url.searchParams.get('category');
const selectedTag = selectedCategory ? null : Astro.url.searchParams.get('tag');
const isListRoute = Astro.url.pathname === '/';
const isCategoryRoute = isListRoute && Boolean(selectedCategory);
const isTagRoute = isListRoute && !selectedCategory && Boolean(selectedTag);
const hasRouteFilter = isCategoryRoute || isTagRoute;
const isSearchRoute = isListRoute && !hasRouteFilter && Astro.url.searchParams.has('search');
const isHomeRoute = Astro.url.pathname === '/' && !isSearchRoute && !hasRouteFilter;
const isWikiRoute = Astro.url.pathname === '/wiki/' || Astro.url.pathname.startsWith('/wiki/');

function categoryHref(category: string) {
	return `/?category=${encodeURIComponent(category)}`;
}

function tagHref(tag: string) {
	return `/?tag=${encodeURIComponent(tag)}`;
}

function isActiveCategory(category: string) {
	if (isCategoryRoute) return selectedCategory === category;
	if (isListRoute) return false;

	return activeCategory === category;
}

function isActiveTag(tag: string) {
	if (isTagRoute) return selectedTag === tag;
	if (isListRoute) return false;

	return activeTags.includes(tag);
}
---

