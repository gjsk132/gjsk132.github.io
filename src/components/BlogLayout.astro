	<aside class="sidebar">
		<section class="sidebar-frame profile-frame">
			<div class="profile-card">
				<div class="avatar">
					<img src="/image.webp" alt="gjsk132 profile" loading="eager" decoding="async" />
				</div>
				<div>
					<strong>gjsk132</strong>
					<p>나만의 지식 저장소</p>
				</div>
			</div>

			<a class="github-card" href="https://github.com/gjsk132">GitHub 바로가기</a>
		</section>

		<section class="sidebar-frame plain-card">
			<h3>Category</h3>
			<div class="category-list">
				{
					categories.map((category) => (
						<a
							href={categoryHref(category)}
							data-category-link={category}
							aria-current={isActiveCategory(category) ? 'page' : undefined}
						>
							<span>{category}</span>
							<strong>{categoryCounts[category] ?? 0}</strong>
						</a>
					))
				}
			</div>
		</section>

		<section class="sidebar-frame plain-card">
			<h3>Tag</h3>
			<div class="tags">
				{
					tags.length > 0 ? (
						tags.map((tag) => (
							<a href={tagHref(tag)} data-tag-link={tag} aria-current={isActiveTag(tag) ? 'page' : undefined}>
								{tag}
							</a>
						))
					) : (
						<p class="empty-side">Obsidian frontmatter에 tags를 추가하면 표시됩니다.</p>
					)
				}
			</div>
		</section>
	</aside>

	<main class="content">
		<slot />
	</main>
</div>

<script>
	const homeButton = document.querySelector('[data-home-button]');
	const searchParams = new URLSearchParams(window.location.search);
	const selectedCategory = searchParams.get('category');
	const selectedTag = searchParams.get('tag');
	const searchOpenButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-search-open]'));
	const topTools = document.querySelector<HTMLElement>('[data-top-tools]');
	const mobileTopbar = document.querySelector<HTMLElement>('[data-mobile-topbar]');
	let lastScrollY = window.scrollY;
	let ticking = false;

	function setTopBarHidden(isHidden: boolean) {
		homeButton?.setAttribute('data-top-hidden', String(isHidden));
		topTools?.setAttribute('data-top-hidden', String(isHidden));
		mobileTopbar?.setAttribute('data-top-hidden', String(isHidden));
	}

	function updateTopBarVisibility() {
		const currentScrollY = window.scrollY;
		const isScrollingDown = currentScrollY > lastScrollY;
		const shouldHide = currentScrollY > 96 && isScrollingDown;

		setTopBarHidden(shouldHide);
		lastScrollY = Math.max(currentScrollY, 0);
		ticking = false;
	}

	homeButton?.addEventListener('click', (event) => {
		if (window.location.pathname === '/' && !window.location.search) {
			event.preventDefault();
		}
	});

	if (selectedCategory || selectedTag) {
		document.querySelectorAll<HTMLElement>('[data-category-link]').forEach((link) => {
			if (link.dataset.categoryLink === selectedCategory) {
				link.setAttribute('aria-current', 'page');
			} else {
				link.removeAttribute('aria-current');
			}
		});

		document.querySelectorAll<HTMLElement>('[data-tag-link]').forEach((link) => {
			if (link.dataset.tagLink === selectedTag) {
				link.setAttribute('aria-current', 'page');
			} else {
				link.removeAttribute('aria-current');
			}
		});
	}

	searchOpenButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const openEvent = new CustomEvent('site-search-open', { cancelable: true });
			const wasHandled = !window.dispatchEvent(openEvent);
			if (!wasHandled && window.location.pathname !== '/') {
				window.location.href = '/?search=1';
			}
		});
	});

	const savedViewMode = window.localStorage.getItem('postViewMode') ?? 'posts';
	const viewModeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-view-button]'));

	viewModeButtons.forEach((button) => {
		button.setAttribute('aria-pressed', String(button.dataset.viewButton === savedViewMode));
	});

	viewModeButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const nextViewMode = button.dataset.viewButton === 'timeline' ? 'timeline' : 'posts';
			window.localStorage.setItem('postViewMode', nextViewMode);

			for (const viewButton of viewModeButtons) {
				viewButton.setAttribute('aria-pressed', String(viewButton.dataset.viewButton === nextViewMode));
			}

			window.dispatchEvent(
				new CustomEvent('post-view-mode-change', {
					detail: nextViewMode,
				}),
			);
		});
	});

	window.addEventListener(
		'scroll',
		() => {
			if (ticking) return;
			ticking = true;
			window.requestAnimationFrame(updateTopBarVisibility);
		},
		{ passive: true },
	);

	const prefetchedUrls = new Set<string>();

	function prefetchInternalLink(link: HTMLAnchorElement) {
		const url = new URL(link.href, window.location.href);
		if (url.origin !== window.location.origin || url.href === window.location.href) return;
		if (prefetchedUrls.has(url.href)) return;

		prefetchedUrls.add(url.href);
		const prefetchLink = document.createElement('link');
		prefetchLink.rel = 'prefetch';
		prefetchLink.href = url.href;
		prefetchLink.as = 'document';
		document.head.append(prefetchLink);
	}

	function prefetchClosestInternalLink(target: EventTarget | null) {
		if (!(target instanceof Element)) return;

		const link = target.closest<HTMLAnchorElement>('a[href^="/"]');
		if (link) prefetchInternalLink(link);
	}

	document.addEventListener('pointerover', (event) => prefetchClosestInternalLink(event.target), {
		passive: true,
	});
	document.addEventListener('focusin', (event) => prefetchClosestInternalLink(event.target));
</script>

<style>
	.blog-layout {
		min-height: 100vh;
		width: min(1080px, 98%);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 244px minmax(0, 1fr);
		grid-template-areas: 'sidebar content';
		align-items: start;
		gap: 24px;
		padding: 66px 0 96px;
		background: transparent;
	}

	.blog-home-button {
		position: fixed;
		top: 18px;
		left: calc(max(1vw, (100vw - 1080px) / 2) + 20px);
		z-index: 10;
		width: 32px;
		height: 32px;
		display: grid;
		place-items: center;
		border: 1px solid rgba(255, 255, 255, 0.75);
		border-radius: 50%;
		background: var(--panel);
		box-shadow: var(--shadow);
		color: var(--text);
		text-decoration: none;
		backdrop-filter: blur(16px);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.blog-home-button[data-top-hidden='true'] {
		transform: translateY(-72px);
		pointer-events: none;
	}

	.blog-home-button[data-top-hidden='true']:hover,
	.blog-home-button[data-top-hidden='true']:focus-visible {
		transform: translateY(-72px);
	}

	.blog-home-button:hover,
	.blog-home-button:focus-visible {
		border-color: color-mix(in srgb, var(--accent) 32%, white);
		color: var(--accent);
		box-shadow: 0 12px 26px rgba(45, 84, 255, 0.12);
		transform: translateY(-1px);
		outline: 0;
	}

	.blog-home-button svg {
		width: 17px;
		height: 17px;
		fill: currentColor;
	}

	.top-tools {
		position: fixed;
		top: 18px;
		right: max(24px, calc((100vw - 1080px) / 2));
		z-index: 10;
		display: flex;
		align-items: center;
		gap: 10px;
		transition:
			opacity 180ms ease,
			transform 180ms ease;
	}

	.top-tools[data-top-hidden='true'] {
		opacity: 0;
		transform: translateY(-72px);
		pointer-events: none;
	}

	.search-button {
		width: 34px;
		height: 34px;
		display: grid;
		place-items: center;
		border: 1px solid rgba(255, 255, 255, 0.5);
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.64);
		color: var(--text);
		cursor: pointer;
		backdrop-filter: blur(16px);
		transition:
			background 160ms ease,
			color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.search-button:hover,
	.search-button:focus-visible {
		background: #fff;
		color: var(--accent);
		box-shadow: 0 12px 26px rgba(45, 84, 255, 0.12);
		transform: translateY(-1px);
		outline: 0;
	}

	.search-button svg {
		width: 18px;
		height: 18px;
		fill: currentColor;
	}

	.top-tools :global(.view-toggle) {
		display: flex;
		align-items: center;
		gap: 4px;
		height: 34px;
		padding: 3px;
		border: 1px solid rgba(255, 255, 255, 0.58);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.64);
		backdrop-filter: blur(16px);
	}

	.top-tools :global(.view-toggle button) {
		width: 28px;
		height: 28px;
		display: grid;
		place-items: center;
		border: 0;
		border-radius: 50%;
		background: transparent;
		color: var(--muted);
		cursor: pointer;
		transition:
			background 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.top-tools :global(.view-toggle button:hover),
	.top-tools :global(.view-toggle button:focus-visible) {
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		color: var(--accent);
		transform: translateY(-1px);
		outline: 0;
	}

	.top-tools :global(.view-toggle button[aria-pressed='true']) {
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
	}

	.top-tools :global(.view-toggle svg) {
		width: 18px;
		height: 18px;
		fill: currentColor;
	}

	.sidebar {
		grid-area: sidebar;
		display: flex;
		flex-direction: column;
		gap: 12px;
		max-height: calc(100vh - 96px);
		overflow-y: auto;
		padding: 14px;
		border: 1px solid rgba(255, 255, 255, 0.62);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.18);
		box-shadow: 0 18px 34px rgba(20, 24, 40, 0.08);
		scrollbar-width: none;
	}

	.sidebar::-webkit-scrollbar {
		width: 6px;
	}

	.sidebar::-webkit-scrollbar-thumb {
		border: 2px solid transparent;
		border-radius: 999px;
		background: rgba(67, 97, 255, 0.3);
		background-clip: padding-box;
	}

	.sidebar::-webkit-scrollbar-thumb:hover {
		background: rgba(67, 97, 255, 0.46);
		background-clip: padding-box;
	}

	.sidebar-frame {
		padding: 0;
		border: 0;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
	}

	.sidebar-frame + .sidebar-frame {
		padding-top: 14px;
		border-top: 1px solid rgba(255, 255, 255, 0.62);
	}

	.profile-card,
	.github-card {
		background: #fff;
		border: 1px solid rgba(255, 255, 255, 0.9);
		border-radius: 18px;
		box-shadow: none;
	}

	.profile-card {
		display: flex;
		align-items: center;
		gap: 12px;
		min-height: 76px;
		padding: 13px 14px;
		margin-bottom: 10px;
	}

	.avatar {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		overflow: hidden;
		border: 2px solid rgba(255, 255, 255, 0.8);
		flex-shrink: 0;
	}

	.avatar img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.profile-card strong {
		display: block;
		margin-bottom: 4px;
	}

	.profile-card p {
		margin: 0;
		color: var(--muted);
		font-size: 12px;
	}

	.github-card {
		display: block;
		min-height: 36px;
		padding: 10px 8px;
		border-radius: 999px;
		text-align: center;
		text-decoration: none;
		font-size: 13px;
		transition:
			box-shadow 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.github-card:hover,
	.github-card:focus-visible {
		color: var(--accent);
		box-shadow: 0 16px 34px rgba(45, 84, 255, 0.11);
		transform: translateY(-1px);
		outline: 0;
	}

	.category-list {
		display: grid;
		gap: 8px;
	}

	.category-list a {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		width: 100%;
		padding: 9px 12px;
		border-radius: 999px;
		background: #fff;
		color: var(--text);
		font-size: 12px;
		text-decoration: none;
		transition:
			background 160ms ease,
			color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.category-list a:hover,
	.category-list a:focus-visible,
	.tags a:hover,
	.tags a:focus-visible {
		background: color-mix(in srgb, var(--accent) 8%, white);
		color: var(--accent);
		box-shadow: 0 10px 22px rgba(45, 84, 255, 0.08);
		transform: translateY(-1px);
		outline: 0;
	}

	.category-list a[aria-current='page'],
	.tags a[aria-current='page'] {
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		font-weight: 700;
	}

	.category-list strong {
		color: var(--accent);
		font-size: 12px;
	}

	.empty-side {
		margin: 0;
		color: var(--muted);
		font-size: 12px;
		line-height: 1.6;
	}

	.plain-card {
		display: block;
	}

	.plain-card h3 {
		margin: 0 0 9px;
		font-size: 13px;
		font-weight: 700;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 7px;
	}

	.tags span,
	.tags a {
		padding: 7px 10px;
		border-radius: 999px;
		background: #fff;
		color: var(--text);
		font-size: 12px;
		text-decoration: none;
	}

	.tags a {
		transition:
			background 160ms ease,
			color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.content {
		grid-area: content;
		max-width: none;
		width: 100%;
		min-width: 0;
	}

	.mobile-topbar {
		display: none;
	}

	@media (max-width: 900px) {
		.blog-layout {
			width: auto;
			grid-template-columns: 1fr;
			grid-template-areas: 'content';
			padding: 76px 12px 96px;
		}

		.blog-home-button {
			display: none;
		}

		.top-tools {
			display: none;
		}

		.sidebar {
			display: none;
		}

		.content {
			width: 100%;
		}

		.mobile-topbar {
			position: fixed;
			top: 10px;
			left: 10px;
			right: 10px;
