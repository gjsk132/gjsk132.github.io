			</svg>
		</button>

		<div class="mobile-view-toggle" role="group" aria-label="보기 형태">
			<button type="button" data-view-button="posts" aria-label="게시글 형태" title="게시글 형태" aria-pressed="true">
				<svg aria-hidden="true" viewBox="0 0 24 24">
					<path d="M6.5 4h11A2.5 2.5 0 0 1 20 6.5v11a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 17.5v-11A2.5 2.5 0 0 1 6.5 4Zm1.4 4.2v2h8.2v-2H7.9Zm0 4v2h8.2v-2H7.9Zm0 4v1.4h5.2v-1.4H7.9Z" />
				</svg>
			</button>
			<button type="button" data-view-button="timeline" aria-label="타임라인 형태" title="타임라인 형태" aria-pressed="false">
				<svg aria-hidden="true" viewBox="0 0 24 24">
					<path d="M10.8 4h2.4v3.2a4.2 4.2 0 0 1 0 7.6V20h-2.4v-5.2a4.2 4.2 0 0 1 0-7.6V4Zm1.2 5.2a2.2 2.2 0 1 0 0 4.4 2.2 2.2 0 0 0 0-4.4ZM17 5h4v2h-4V5Zm0 6h4v2h-4v-2Zm0 6h4v2h-4v-2ZM3 5h4v2H3V5Zm0 12h4v2H3v-2Z" />
				</svg>
