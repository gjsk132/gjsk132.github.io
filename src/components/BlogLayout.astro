<script>
	const homeButton = document.querySelector('[data-home-button]');
	const searchParams = new URLSearchParams(window.location.search);
	const selectedCategory = searchParams.get('category');
	const selectedTag = selectedCategory ? null : searchParams.get('tag');
	const searchOpenButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-search-open]'));
	const categoryLinks = Array.from(document.querySelectorAll<HTMLElement>('[data-category-link]'));
	const tagLinks = Array.from(document.querySelectorAll<HTMLElement>('[data-tag-link]'));
	const topTools = document.querySelector<HTMLElement>('[data-top-tools]');
	const mobileTopbar = document.querySelector<HTMLElement>('[data-mobile-topbar]');
	const mobileFilters = Array.from(document.querySelectorAll<HTMLDetailsElement>('[data-mobile-filter]'));
	let lastScrollY = window.scrollY;
	let ticking = false;

	function setTopBarHidden(isHidden: boolean) {
		homeButton?.setAttribute('data-top-hidden', String(isHidden));
		topTools?.setAttribute('data-top-hidden', String(isHidden));
		mobileTopbar?.setAttribute('data-top-hidden', String(isHidden));
	}

	function updateTopBarVisibility() {
		const currentScrollY = window.scrollY;
		const isScrollingDown = currentScrollY > lastScrollY;
		const shouldHide = currentScrollY > 96 && isScrollingDown;

		setTopBarHidden(shouldHide);
		lastScrollY = Math.max(currentScrollY, 0);
		ticking = false;
	}

	homeButton?.addEventListener('click', (event) => {
		if (window.location.pathname === '/' && window.location.search) {
			event.preventDefault();
			window.location.href = '/';
			return;
		}

		if (window.location.pathname === '/' && !window.location.search) {
			event.preventDefault();
			document.documentElement.dataset.listState = 'home';
			homeButton.setAttribute('aria-current', 'page');
			for (const searchOpenButton of searchOpenButtons) {
				searchOpenButton.removeAttribute('aria-current');
			}
			for (const categoryLink of categoryLinks) {
				categoryLink.removeAttribute('aria-current');
			}
			for (const tagLink of tagLinks) {
				tagLink.removeAttribute('aria-current');
			}
			window.dispatchEvent(new CustomEvent('site-search-close'));
		}
	});

	if (selectedCategory || selectedTag) {
		document.documentElement.dataset.listState = selectedCategory ? 'category' : 'tag';
		homeButton?.removeAttribute('aria-current');
		for (const searchOpenButton of searchOpenButtons) {
			searchOpenButton.removeAttribute('aria-current');
		}

		categoryLinks.forEach((link) => {
			if (link.dataset.categoryLink === selectedCategory) {
				link.setAttribute('aria-current', 'page');
			} else {
				link.removeAttribute('aria-current');
			}
		});

		tagLinks.forEach((link) => {
			if (link.dataset.tagLink === selectedTag) {
				link.setAttribute('aria-current', 'page');
			} else {
				link.removeAttribute('aria-current');
			}
		});
	}

	searchOpenButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const openEvent = new CustomEvent('site-search-open', { cancelable: true });
			const wasHandled = !window.dispatchEvent(openEvent);
			if (!wasHandled && window.location.pathname !== '/') {
				window.location.href = '/?search=1';
				return;
			}

			if (window.location.pathname === '/') {
				window.history.replaceState(null, '', '/?search=1');
			}

			document.documentElement.dataset.listState = 'search';
			homeButton?.removeAttribute('aria-current');
			for (const searchOpenButton of searchOpenButtons) {
				searchOpenButton.setAttribute('aria-current', 'page');
			}
			for (const categoryLink of categoryLinks) {
				categoryLink.removeAttribute('aria-current');
			}
			for (const tagLink of tagLinks) {
				tagLink.removeAttribute('aria-current');
			}
		});
	});

	const savedViewMode = window.localStorage.getItem('postViewMode') ?? 'posts';
	const viewModeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-view-button]'));

	viewModeButtons.forEach((button) => {
		button.setAttribute('aria-pressed', String(button.dataset.viewButton === savedViewMode));
	});

	viewModeButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const nextViewMode = button.dataset.viewButton === 'timeline' ? 'timeline' : 'posts';
			window.localStorage.setItem('postViewMode', nextViewMode);

			for (const viewButton of viewModeButtons) {
				viewButton.setAttribute('aria-pressed', String(viewButton.dataset.viewButton === nextViewMode));
			}

			window.dispatchEvent(
				new CustomEvent('post-view-mode-change', {
					detail: nextViewMode,
				}),
			);
		});
	});

	function positionMobileFilterMenu(filter: HTMLDetailsElement) {
		const menu = filter.querySelector<HTMLElement>('.mobile-filter-menu');
		if (!menu) return;

		menu.style.setProperty('--mobile-menu-shift', '0px');

		window.requestAnimationFrame(() => {
			const menuRect = menu.getBoundingClientRect();
			const gutter = 10;
			let shift = 0;

			if (menuRect.left < gutter) {
				shift = gutter - menuRect.left;
			} else if (menuRect.right > window.innerWidth - gutter) {
				shift = window.innerWidth - gutter - menuRect.right;
			}

			menu.style.setProperty('--mobile-menu-shift', `${shift}px`);
		});
	}

	mobileFilters.forEach((filter) => {
		filter.addEventListener('toggle', () => {
			if (!filter.open) return;

			for (const otherFilter of mobileFilters) {
				if (otherFilter !== filter) otherFilter.open = false;
			}

			positionMobileFilterMenu(filter);
		});
	});

	window.addEventListener('resize', () => {
		for (const filter of mobileFilters) {
			if (filter.open) positionMobileFilterMenu(filter);
		}
	});

	window.addEventListener(
		'scroll',
		() => {
			if (ticking) return;
			ticking = true;
			window.requestAnimationFrame(updateTopBarVisibility);
		},
		{ passive: true },
	);

	const prefetchedUrls = new Set<string>();

	function prefetchInternalLink(link: HTMLAnchorElement) {
		const url = new URL(link.href, window.location.href);
		if (url.origin !== window.location.origin || url.href === window.location.href) return;
		if (prefetchedUrls.has(url.href)) return;

		prefetchedUrls.add(url.href);
		const prefetchLink = document.createElement('link');
		prefetchLink.rel = 'prefetch';
		prefetchLink.href = url.href;
		prefetchLink.as = 'document';
		document.head.append(prefetchLink);
	}

	function prefetchClosestInternalLink(target: EventTarget | null) {
		if (!(target instanceof Element)) return;

		const link = target.closest<HTMLAnchorElement>('a[href^="/"]');
		if (link) prefetchInternalLink(link);
	}

	document.addEventListener('pointerover', (event) => prefetchClosestInternalLink(event.target), {
		passive: true,
	});
	document.addEventListener('focusin', (event) => prefetchClosestInternalLink(event.target));
</script>

<style>
	.blog-layout {
		--nav-active-bg: #eef1ff;
		--nav-active-border: transparent;
		--nav-active-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.78), 0 10px 24px rgba(67, 97, 255, 0.12);
		--topbar-hover-shadow: 0 12px 26px rgba(45, 84, 255, 0.12);
		min-height: 100vh;
		width: min(1080px, 98%);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 244px minmax(0, 1fr);
		grid-template-areas: 'sidebar content';
		align-items: start;
		gap: 24px;
		padding: 66px 0 96px;
		background: transparent;
	}

	.blog-home-button {
		position: fixed;
		top: 18px;
		left: calc(max(1vw, (100vw - 1080px) / 2) + 20px);
		z-index: 10;
		width: 32px;
		height: 32px;
		display: grid;
		place-items: center;
		border: 1px solid rgba(255, 255, 255, 0.75);
		border-radius: 50%;
		background: var(--panel);
		box-shadow: var(--shadow);
		color: var(--text);
		text-decoration: none;
		backdrop-filter: blur(16px);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.blog-home-button[data-top-hidden='true'] {
		transform: translateY(-72px);
		pointer-events: none;
	}

	.blog-home-button[data-top-hidden='true']:hover,
	.blog-home-button[data-top-hidden='true']:focus-visible {
		transform: translateY(-72px);
	}

	.blog-home-button:hover,
	.blog-home-button:focus-visible {
		border-color: rgba(255, 255, 255, 0.5);
		background: #fff;
		color: var(--accent);
		box-shadow: var(--topbar-hover-shadow);
		outline: 0;
	}

	.blog-home-button[aria-current='page'] {
		border-color: var(--nav-active-border);
		background: var(--nav-active-bg);
		color: var(--accent);
		box-shadow: var(--nav-active-shadow);
		outline: 0;
	}

