				<path d="M12 4.2 5.1 9.7c-.5.4-.8 1-.8 1.7v5.7c0 1 .8 1.8 1.8 1.8h3.2v-4.3c0-.8.6-1.4 1.4-1.4h2.6c.8 0 1.4.6 1.4 1.4v4.3h3.2c1 0 1.8-.8 1.8-1.8v-5.7c0-.7-.3-1.3-.8-1.7L12 4.2Z" />
