---
interface WikiTerm {
	slug: string;
	title: string;
	definition: string;
	definitions?: {
		title: string;
		define: string;
	}[];
}

interface Props {
	entries: WikiTerm[];
	targetSelector?: string;
}

const targetSelector = Astro.props.targetSelector ?? ".article-content";
const terms = Astro.props.entries
	.map((entry) => ({
		slug: entry.slug,
		title: entry.title.trim(),
		definition: entry.definition.trim(),
		definitions: entry.definitions ?? [],
	}))
	.filter((entry) => entry.title && entry.definition)
	.sort((a, b) => b.title.length - a.title.length);
---

<template data-wiki-terms data-target-selector={targetSelector}>{JSON.stringify(terms)}</template>

<script is:inline>
	(() => {
		const source = document.querySelector("template[data-wiki-terms]");
		const targetSelector = source?.dataset.targetSelector || ".article-content";

		function run() {
			const roots = Array.from(document.querySelectorAll(targetSelector));

			if (!source || roots.length === 0) return;

			const hasEnhancedRoot = roots.some(
				(root) => root.dataset.wikiTermsEnhanced === "true",
			);

			if (hasEnhancedRoot) return;

			roots.forEach((root) => {
				root.dataset.wikiTermsEnhanced = "true";
			});

			let terms = [];

			try {
				terms = JSON.parse(source.content.textContent || "[]");
			} catch {
				return;
			}

			if (!terms.length) return;

			const termsByTitle = new Map(
				terms.map((term) => [term.title.toLowerCase(), term]),
			);
			const highlightedSlugs = new Set();

			function escapeRegExp(value) {
				return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
			}

			function termPattern(term) {
				const escapedTerm = escapeRegExp(term.title);
				const isAsciiWord = /^[A-Za-z0-9 _-]+$/.test(term.title);

				if (!isAsciiWord) return escapedTerm;

				return `(?<![A-Za-z0-9])${escapedTerm}(?![A-Za-z0-9])`;
			}

			const pattern = terms.map(termPattern).filter(Boolean).join("|");

			if (!pattern) return;

			const matcher = new RegExp(pattern, "gi");

			for (const root of roots) {
				const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
					acceptNode(node) {
						const parent = node.parentElement;
						const text = node.nodeValue || "";

						if (!parent || !text.trim()) return NodeFilter.FILTER_REJECT;
						if (
							parent.closest(
								"a, code, pre, script, style, textarea, input, button, .wiki-term-link",
							)
						) {
							return NodeFilter.FILTER_REJECT;
						}

						matcher.lastIndex = 0;

						if (!matcher.test(text)) return NodeFilter.FILTER_REJECT;

						matcher.lastIndex = 0;
						return NodeFilter.FILTER_ACCEPT;
					},
				});
				const textNodes = [];

				while (walker.nextNode()) {
					textNodes.push(walker.currentNode);
				}

				for (const node of textNodes) {
					const text = node.nodeValue || "";
					const fragment = document.createDocumentFragment();
					let lastIndex = 0;
					let hasReplacement = false;

					matcher.lastIndex = 0;
					text.replace(matcher, (match, offset) => {
						const term = termsByTitle.get(match.toLowerCase());

						if (!term || highlightedSlugs.has(term.slug)) return match;

						if (offset > lastIndex) {
							fragment.append(
								document.createTextNode(text.slice(lastIndex, offset)),
							);
						}

						const marker = document.createElement("span");
						marker.className = "wiki-term-link";
						marker.textContent = match;
						marker.dataset.definition = termDefinition(term);
						marker.setAttribute("tabindex", "0");
						marker.append(createTooltip(term));
						marker.addEventListener("mouseenter", positionTooltip);
						marker.addEventListener("focus", positionTooltip);

						fragment.append(marker);
						highlightedSlugs.add(term.slug);
						lastIndex = offset + match.length;
						hasReplacement = true;

						return match;
					});

					if (!hasReplacement) continue;

					if (lastIndex < text.length) {
						fragment.append(document.createTextNode(text.slice(lastIndex)));
					}

					node.parentNode?.replaceChild(fragment, node);
				}
			}
		}

		function positionTooltip(event) {
			const marker = event.currentTarget;
			const markerRect = marker.getBoundingClientRect();
			const tooltipWidth = Math.min(260, window.innerWidth - 32);
			const markerCenter = markerRect.left + markerRect.width / 2;
			const minLeft = 16;
			const maxRight = window.innerWidth - 16;
			const tooltipLeft = markerCenter - tooltipWidth / 2;
			const tooltipRight = markerCenter + tooltipWidth / 2;
			let shift = 0;

			if (tooltipLeft < minLeft) {
				shift = minLeft - tooltipLeft;
			} else if (tooltipRight > maxRight) {
				shift = maxRight - tooltipRight;
			}

			marker.style.setProperty("--wiki-tooltip-shift", `${shift}px`);
		}

		function termDefinition(term) {
			if (!Array.isArray(term.definitions) || term.definitions.length < 2) {
				return term.definition;
			}

			const summaries = term.definitions
				.slice(0, 3)
				.map((definition, index) => `[${index + 1}] ${definition.title}\n${definition.define}`)
				.join("\n\n");
			const suffix = term.definitions.length > 3 ? `\n외 ${term.definitions.length - 3}개` : "";

			return `${summaries}${suffix}`;
		}

		function termDefinitionItems(term) {
			if (!Array.isArray(term.definitions) || term.definitions.length < 2) {
				return [{ title: "", define: term.definition }];
			}

			return term.definitions.slice(0, 3);
		}

		function createTooltip(term) {
			const tooltip = document.createElement("span");
			tooltip.className = "wiki-term-tooltip";
			tooltip.setAttribute("aria-hidden", "true");

			termDefinitionItems(term).forEach((definition, index) => {
				const row = document.createElement("span");
				row.className = "wiki-term-tooltip-row";

				if (definition.title) {
					const number = document.createElement("span");
					number.className = "wiki-term-tooltip-number";
					number.textContent = `[${index + 1}]`;

					const title = document.createElement("strong");
					title.textContent = definition.title;

					const body = document.createElement("em");
					body.textContent = definition.define;

					row.append(number, title, body);
				} else {
					const body = document.createElement("em");
					body.textContent = definition.define;
					row.append(body);
				}

				tooltip.append(row);
			});

			if (Array.isArray(term.definitions) && term.definitions.length > 3) {
				const more = document.createElement("span");
				more.className = "wiki-term-tooltip-more";
				more.textContent = `외 ${term.definitions.length - 3}개`;
				tooltip.append(more);
			}

			return tooltip;
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", run, { once: true });
		} else {
			run();
		}
	})();
</script>

<style is:global>
	.post-card .wiki-term-link {
		position: relative;
		display: inline;
		border-radius: 4px;
		background: linear-gradient(transparent 34%, #e6e9ff 34%);
		-webkit-box-decoration-break: clone;
		box-decoration-break: clone;
		--wiki-tooltip-shift: 0px;
		color: inherit;
		font-weight: inherit;
		text-decoration: none;
		cursor: default;

		transition: background 160ms ease;
	}

	.post-card .wiki-term-link:hover,
	.post-card .wiki-term-link:focus-visible {
		background: linear-gradient(transparent 22%, #dce1ff 22%);
		color: inherit;
		outline: 0;
	}

	.post-card .wiki-term-tooltip {
		position: absolute;
		left: 50%;
		bottom: calc(100% + 10px);

		z-index: 20;

		width: max-content;
		max-width: min(260px, calc(100vw - 32px));

		display: grid;
		gap: 9px;
		padding: 10px 12px;
		border: 1px solid color-mix(in srgb, var(--accent) 16%, var(--line));
		border-radius: 12px;

		background: rgba(255, 255, 255, 0.96);
		color: var(--text);

		font-size: 12px;
		font-weight: 500;
		line-height: 1.55;
		white-space: normal;
		text-align: left;

		box-shadow: 0 10px 22px rgba(20, 24, 40, 0.09);

		transform: translateX(calc(-50% + var(--wiki-tooltip-shift))) translateY(5px);
		opacity: 0;
		pointer-events: none;

		transition:
			opacity 0s linear,
			transform 0s linear;
	}

	.post-card .wiki-term-tooltip-row {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		column-gap: 7px;
		row-gap: 2px;
	}

	.post-card .wiki-term-tooltip-number {
		color: var(--accent);
		font-weight: 800;
	}

	.post-card .wiki-term-tooltip strong {
		color: var(--text);
		font-size: 12px;
		font-weight: 800;
		line-height: 1.4;
	}

	.post-card .wiki-term-tooltip em {
		grid-column: 2;
		color: var(--muted);
		font-size: 12px;
		font-style: normal;
		font-weight: 500;
		line-height: 1.55;
	}

	.post-card .wiki-term-tooltip-row:first-child:last-child em {
		grid-column: 1 / -1;
	}

	.post-card .wiki-term-tooltip-more {
		color: var(--muted);
		font-size: 11px;
		font-weight: 700;
	}

	.post-card .wiki-term-link::before {
		content: '';
		position: absolute;
		left: 50%;
		bottom: calc(100% + 5px);
		z-index: 21;
		width: 9px;
		height: 9px;
		border-right: 1px solid color-mix(in srgb, var(--accent) 16%, var(--line));
		border-bottom: 1px solid color-mix(in srgb, var(--accent) 16%, var(--line));
		background: rgba(255, 255, 255, 0.96);
		transform: translateX(-50%) translateY(5px) rotate(45deg);
		opacity: 0;
		pointer-events: none;
		transition:
			opacity 0s linear,
			transform 0s linear;
	}

	.post-card .wiki-term-link:hover .wiki-term-tooltip,
	.post-card .wiki-term-link:focus-visible .wiki-term-tooltip {
		opacity: 1;
		transform: translateX(calc(-50% + var(--wiki-tooltip-shift))) translateY(0);

		transition:
			opacity 160ms ease 450ms,
			transform 160ms ease 450ms;
	}

	.post-card .wiki-term-link:hover::before,
	.post-card .wiki-term-link:focus-visible::before {
		opacity: 1;
		transform: translateX(-50%) translateY(0) rotate(45deg);
		transition:
			opacity 160ms ease 450ms,
			transform 160ms ease 450ms;
	}

</style>
